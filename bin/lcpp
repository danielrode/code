#!/usr/bin/env python3
# author: daniel rode
# dependencies: podman, podman-compose, aria2
# created: 07 feb 2026
# updated: 14 may 2026


# Run LLMs (AI chat) locally via llama.cpp.
#
# ssh -tL 5001:localhost:5001 REMOTE_IP ~/code/bin/lcpp Qwen2.5-7B-Instruct-Q4_0


import sys
import shutil
import socket
import hashlib
import subprocess as sp
from os import sysconf
from pathlib import Path
from tempfile import TemporaryDirectory

import yaml


HOME = Path.home()
RAM_GB = (sysconf('SC_PAGE_SIZE') * sysconf('SC_PHYS_PAGES')) / (1024.**3)
HOSTNAME = socket.gethostname()

CACHE_DIR = HOME / ".cache"
GGUF_MODEL_DIR = CACHE_DIR / "com.github.danielrode/lcpp/gguf"

DEFAULT_MODELS = [
    'gemma-3-1b-it-BF16',
    'Falcon3-3B-Instruct-q4_0',
    'Qwen2.5-Coder-3B-Instruct-Q4_0',
]
if RAM_GB > 30:
    DEFAULT_MODELS += [
        'Qwen2.5-7B-Instruct-Q4_0',
        'qwen2.5-coder-7b-instruct-q4_k_m',
        'gemma-4-E4B-it-Q4_0',
    ]
if RAM_GB > 120:
    DEFAULT_MODELS += [
        'Qwen2.5-Coder-14B-Instruct-Q4_0',
    ]
MODEL_LIST = [
    # Useful model lists:
    # - https://huggingface.co/bartowski
    # - https://huggingface.co/unsloth
    'Manojb/Qwen3-4B-toolcalling-gguf-codex:Qwen3-4B-Function-Calling-Pro',
    'Qwen/Qwen2.5-Coder-7B-Instruct-GGUF:qwen2.5-coder-7b-instruct-q4_k_m',  # 4.7 GB
    'bartowski/Meta-Llama-3.1-8B-Instruct-GGUF:Meta-Llama-3.1-8B-Instruct-Q8_0',
    'bartowski/Ministral-8B-Instruct-2410-GGUF:Ministral-8B-Instruct-2410-Q8_0',  # 8.5 GB
    'bartowski/Qwen2.5-7B-Instruct-GGUF:Qwen2.5-7B-Instruct-Q4_0',  # 4.1 GB
    'bartowski/Qwen2.5-Coder-14B-Instruct-GGUF:Qwen2.5-Coder-14B-Instruct-Q4_0',  # 8.5 GB
    'bartowski/Qwen2.5-Coder-14B-Instruct-GGUF:Qwen2.5-Coder-14B-Instruct-Q8_0',  # 16 GB
    'bartowski/Qwen2.5-Coder-3B-Instruct-GGUF:Qwen2.5-Coder-3B-Instruct-Q4_0',  # 1.8 GB
    'bartowski/gemma-2-9b-it-GGUF:gemma-2-9b-it-Q8_0_L',  # 10.7 GB
    'tiiuae/Falcon3-3B-Instruct-GGUF:Falcon3-3B-Instruct-q4_0',  # 1.9 GB
    'unsloth/GLM-4.7-Flash-GGUF:GLM-4.7-Flash-Q4_0',
    'unsloth/gemma-3-1b-it-GGUF:gemma-3-1b-it-BF16',  # 1.8 GB
    'unsloth/gemma-4-E2B-it-GGUF:gemma-4-E2B-it-Q4_0',  # 3.0 GB,
    'unsloth/gemma-4-E4B-it-GGUF:gemma-4-E4B-it-Q4_0',  # 4.8
]
MODEL_MAP = {
    model: repo
    for i in MODEL_LIST
    for repo, model in [i.split(':')]
}

CON_IMG = 'ghcr.io/ggml-org/llama.cpp:server-vulkan'
CON_PORT = 5001
CON_SERVICES = {
    'llamacpp': {
        'image': CON_IMG,
        'devices': [
            '/dev/dri',
        ],
        'volumes': [
            str(GGUF_MODEL_DIR) + ':/models:ro,z',
        ],
        'environment': [
            # https://github.com/ggml-org/llama.cpp/blob/master/tools/server/README.md

            'LLAMA_ARG_WEBUI=true',
            'LLAMA_ARG_HOST=0.0.0.0',
            'LLAMA_ARG_PORT={}'.format(CON_PORT),

            # Router mode settings
            'LLAMA_ARG_MODELS_DIR=/models/',
            # 'LLAMA_ARG_MODELS_PRESET=PATH', # TODO
            'LLAMA_ARG_MODELS_MAX=1',
            # 'LLAMA_ARG_MODELS_MAX=2',
            # 'LLAMA_ARG_MODELS_AUTOLOAD=enabled',
            'LLAMA_ARG_MODELS_AUTOLOAD=disabled',

            # Number of tokens to predict (-1 = inf)
            'LLAMA_ARG_N_PREDICT=-1',

            # Max number of layers to store in VRAM
            # 'LLAMA_ARG_N_GPU_LAYERS=64',
            # 'LLAMA_ARG_N_GPU_LAYERS=99',
            'LLAMA_ARG_N_GPU_LAYERS=auto',
        ],
        'ports': [
            f'127.0.0.1:{CON_PORT}:{CON_PORT}',
        ],
        'restart': 'unless-stopped',
    },
}
CON_COMPOSE = {
    'version': 3.2,
    'services': CON_SERVICES,
}


def sha1(text: str) -> str:
    """Return SHA1 hash of string."""

    return hashlib.sha1(bytes(text, 'utf8')).hexdigest()


# Parse command line input
models = [i.removesuffix(".gguf") for i in sys.argv[1:]]
if not models:
    models = DEFAULT_MODELS

for m in models:
    if m not in MODEL_MAP:
        print("error: Model not found:", m)
        sys.exit(1)

# Download model(s), if needed
urls = []
for m in models:
    repo = MODEL_MAP[m]
    fname = m + ".gguf"

    if not (GGUF_MODEL_DIR / fname).exists():
        u = f'https://huggingface.co/{repo}/resolve/main/{fname}'
        hash = sha1(u)
        dst = Path(GGUF_MODEL_DIR, '.tmp_aria', hash)
        dst.mkdir(parents=True, exist_ok=True)
        urls += [{
            'repo': repo,
            'fname': fname,
            'url': u,
            'hash': hash,
            'tmp_dst_dir': dst,
        }]

if urls:
    aria_input = '\n'.join([
        f"{i['url']}\n\tdir={i['tmp_dst_dir']}"
        for i in urls
    ])
    cmd = (
        'aria2c',
        '--force-sequential=true',
        '--input-file=-',
    )
    sp.run(cmd, check=True, text=True, input=aria_input)

    for i in urls:
        next(i['tmp_dst_dir'].glob('*')).rename(GGUF_MODEL_DIR / i['fname'])

    shutil.rmtree(GGUF_MODEL_DIR / '.tmp_aria')

# Update llama.cpp, if needed
cmd = ('podman', 'pull', '--policy=newer', CON_IMG)
sp.run(cmd, check=True)

# Run llama.cpp
cmd = [
    'podman-compose',
    '--file', '-',
]
con_yaml = yaml.dump(CON_COMPOSE)
try:
    sp.run([*cmd, 'up'], input=con_yaml, text=True)
except KeyboardInterrupt:
    sp.run([*cmd, 'down'], input=con_yaml, text=True)


# todo https://huggingface.co/blog/ggml-org/model-management-in-llamacpp

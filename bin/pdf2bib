#!/usr/bin/env python3
# author: daniel rode
# created: 11 may 2026


# Get and print BibTeX entry for a given PDF article.


import sys
import shutil
import subprocess as sp
from pathlib import Path
from tempfile import TemporaryDirectory


# Constants
CON_IMG = 'ghcr.io/danielrode/pdf2bib:latest'
PY_PAYLOAD = r'''
import pdf2bib
pdf2bib.config.set("verbose", False)
[
    print(i["bibtex"] + "\n")
    for i in pdf2bib.pdf2bib("/in/")
]
'''


# Functions
def print2(*args, **kwargs):
    print(*args, **kwargs, file=sys.stderr)


# Parse command line arguments
src_pdfs = [Path(i) for i in sys.argv[1:]]
for i in src_pdfs:
    if not i.exists():
        print2("error: Path not found:", i)
        sys.exit(1)

if not src_pdfs:
    print2("error: No path provided")
    sys.exit(1)

# Setup tempdir and run container
with TemporaryDirectory() as td:
    td = Path(td)

    for i, fp in enumerate(src_pdfs):
        dst = Path(td, "{}.pdf".format(i))
        shutil.copy(fp, dst)
        dst.chmod(0o0644)

    p = sp.run([
        'podman', 'run',
        '--rm',
        '--user=1111:1111',
        '--read-only',
        '--security-opt=no-new-privileges:true',
        '--cap-drop=ALL',
        '--privileged=false',
        '--entrypoint=python3',
        *(
            f'--volume={fp}:/in/{fp.name}:ro'
            for fp in td.iterdir()
        ),
        CON_IMG,
        '-c', PY_PAYLOAD,
    ])

sys.exit(p.returncode)

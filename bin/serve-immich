#!/usr/bin/env python3
# author: daniel rode
# created: 08 apr 2025
# updated: 10 may 2026


# Run Immich server.


import sys
import tomllib
import subprocess as sp
from pathlib import Path

import yaml


EXE_NAME = Path(__file__).name

HOME = Path.home()
NUNYUH = tomllib.loads(Path(HOME, '.nunyuh').read_text())
IMG_DIR = HOME / 'media/immich'

DATA_HOME = Path(
    HOME,
    '.local',
    'share',
    'com.github.danielrode',
    EXE_NAME,
)
CACHE_HOME = Path(
    HOME,
    '.cache',
    'com.github.danielrode',
    EXE_NAME,
)

IMMICH_VER = 'release'

CON_SERVICES = {
    'redis': {
        'image': 'docker.io/redis:6.2-alpine',
        'container_name': 'immich_redis',
        'restart': 'always',
    },
    'postgres': {  # database
        'image': 'docker.io/tensorchord/pgvecto-rs:pg14-v0.2.0',
        'container_name': 'immich_postgres',
        'restart': 'always',
        'environment': [
            'POSTGRES_PASSWORD=' + NUNYUH['SERVES']['immich_db_pw'],
            'POSTGRES_USER=postgres',
            'POSTGRES_DB=immich',
            'POSTGRES_INITDB_ARGS=--data-checksums',
        ],
        'volume': [
            'immich_postgres:/var/lib/postgresql/data',
        ],
        'cmd': [
            'postgres',
            '-c', 'shared_preload_libraries=vectors.so',
            '-c', 'search_path="$$user", public, vectors',
            '-c', 'logging_collector=on',
            '-c', 'max_wal_size=2GB',
            '-c', 'shared_buffers=512MB',
            '-c', 'wal_compression=on',
        ],
    },
    'ml': {  # immich-machine-learning
        'image': 'ghcr.io/immich-app/immich-machine-learning:' + IMMICH_VER,
        'container_name': 'immich_ml',
        'restart': 'always',
        'environment': [
            'UPLOAD_LOCATION=' + str(IMG_DIR),
            'DB_DATA_LOCATION=./postgres',
            'TZ=America/Denver',
            'IMMICH_VERSION=' + IMMICH_VER,
            'DB_PASSWORD=' + NUNYUH['SERVES']['immich_db_pw'],
            'DB_USERNAME=postgres',
            'DB_DATABASE_NAME=immich',
        ],
        'volumes': [
            'immich_model_cache:/cache',
        ],
    },
    'server': {  # immich
        'image': 'ghcr.io/immich-app/immich-server:' + IMMICH_VER,
        'container_name': 'immich_server',
        'restart': 'always',
        'depends_on': ['redis', 'postgres'],
        'ports': ['2283:2283'],
        'environment': [
            'DB_PASSWORD=' + NUNYUH['SERVES']['immich_db_pw'],
            'DB_USERNAME=postgres',
            'DB_DATABASE_NAME=immich',
        ],
        'volumes': [
            '{}:/usr/src/app/upload:z'.format(IMG_DIR),
            '/etc/localtime:/etc/localtime:ro',
        ],
    },
}
CON_COMPOSE = {
    'name': EXE_NAME,
    'services': CON_SERVICES,
    'volumes': {
        'immich_postgres': {
            'external': True,
            'name': 'immich_postgres',
        },
        'immich_model_cache': {
            'external': True,
            'name': 'immich_model_cache',
        },
    },
}


# Main
IMG_DIR.mkdir(parents=True, exist_ok=True)
DATA_HOME.mkdir(parents=True, exist_ok=True)

print("Access Immich at http://localhost:2283/")

cmd = (
    'podman-compose',
    '--no-ansi',
    '--podman-pull-args=--pull=missing',
    '--file=-',
    'up',
)
sp.run(cmd, check=True, text=True, input=yaml.dump(CON_COMPOSE))

sys.exit(0)


# TODO look into podman secrets

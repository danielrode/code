#!/usr/bin/env dash
# author: daniel rode
# dependencies: hx
# created: 15 jan 2021
# updated: 23 may 2026


# New note. Creates a new text file (note) in my notes directory with
# the date and time as its file name, then opens the file in a text editor.


NOTES_DIR="$HOME/union/notes/cursory"


mkdir -p "$NOTES_DIR"
cd "$NOTES_DIR"
printf "\033]7;file://$HOSTNAME$PWD\033\\"  # Notify terminal of cd
hx --working-dir "$NOTES_DIR" "$NOTES_DIR/$(date '+%Y%m%d%H%M%S').md"

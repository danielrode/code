#!/usr/bin/env bash
# author: daniel rode
# dependencies: lf, fish
# created: 25 mar 2026
# updated: 27 apr 2026


# Run lf file manager, and ensure it always exits to a fish shell, and that
# fish changes directory to where lf was.

# Inspired by https://github.com/gokcehan/lf/blob/master/etc/lfcd.fish

if [[ -d $LF_WILL_DIR && ! -L "$LF_WILL_DIR/cwd" ]]; then
    cp -TP /proc/self/cwd "$LF_WILL_DIR/cwd"
    exit
fi

export LF_WILL_DIR="$(mktemp -d)"
function cleanup { rm -fr -- "$LF_WILL_DIR"; }

while true; do
    /usr/bin/lf "$@"
    [[ ! -L "$LF_WILL_DIR/cwd" ]] && exit
    cd "$(readlink "$LF_WILL_DIR/cwd")"
    unlink "$LF_WILL_DIR/cwd"

    /usr/bin/fish
    [[ ! -L "$LF_WILL_DIR/cwd" ]] && exit
    cd "$(readlink "$LF_WILL_DIR/cwd")"
    unlink "$LF_WILL_DIR/cwd"
done

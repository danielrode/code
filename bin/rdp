#!/usr/bin/env python3
# author: daniel rode
# dependencies:
#   freerdp
#   ~/.nunyuh
# created: 15 jul 2025
# updated: 18 may 2026


# Alias/shortcuts for starting RDP (remote desktop) sessions.


import re
import sys
import i3ipc
import shutil
import socket
import tomllib
import subprocess as sp
from pathlib import Path
from getpass import getpass


HOME = Path.home()
HOSTNAME = socket.gethostname()
FREERDP_ARGS = [
    '/clipboard',
]
NY = tomllib.loads(Path(HOME / '.nunyuh').read_text())['H']


# Parse command line arguments
try:
    remote = sys.argv[1]
except IndexError:
    print("Provide host alias")
    sys.exit(1)

# Set values for remote host
for k in NY:
    try:
        a = NY[k]['alias']
    except KeyError:
        a = None

    if (remote == k.lower()) or (remote == a):
        host = NY[k]
        break
else:
    print("error: Unknown alias:", remote)
    sys.exit(1)

del NY

domain = host["domain"]
user = host["user"]
ip = host["ip"]

# Determine Sway output (screen) resolution
sway = i3ipc.Connection()
focused_output = next((o for o in sway.get_outputs() if o.focused), None)
if not focused_output:
    raise Exception("Could not determine Sway display resolution")
scale = focused_output.scale
w = focused_output.rect.width
h = focused_output.rect.height
FREERDP_ARGS += [
    # '/scale-desktop:' + str(int(scale * 100)),
    # '/scale:180',
    '/w:' + str(int(w - (w * 0.01))),
    '/h:' + str(int(h - (h * 0.1))),
]

# Find and set path to FreeRDP executable
exe = None
for i in (
    'sdl-freerdp',
    'sdl3-freerdp3',
):
    exe = shutil.which(i)
    if exe is not None:
        break
if exe is None:
    print("error: No FreeRDP installation detected")
    sys.exit(2)

# Run FreeRDP
cmd = [exe, '/args-from:stdin']
args_str = '\n'.join((
    *FREERDP_ARGS,
    "/d:" + domain,
    "/u:" + user,
    "/v:" + ip,
    "/p:" + getpass(),
))
print("Calling:", cmd)
print(re.sub('^/p:.*$', '/p:******', args_str, flags=re.MULTILINE))
try:
    sp.run(cmd, text=True, input=args_str)
except KeyboardInterrupt:
    pass

#!/usr/bin/env python3
# author: daniel rode
# dependencies: podman
# created: 21 jul 2025
# updated: 24 jun 2026


import sys
import subprocess as sp
from pathlib import Path

# TODO make podman error if mount mounted with 'readonly' flag has sub-mounts (as podman will make them rw by default)


HELP = "Usage: gis-utils UTILITY_NAME [ARGS...]"
PWD = Path.cwd()
HOME = Path.home()
GIT_REPO_PATH = HOME / 'union/github/gis-utils'
CON_IMG = 'ghcr.io/danielrode/gis-utils:dev'
CON_ARGS = (
    '--rm',
    '--tty',
    '--interactive',
    # '--oom-score-adj=999',
    '--mount=type=bind,source=/etc/localtime,target=/etc/localtime',
    '--mount=type=bind,source=/tmp,target=/tmp',
    '--mount=type=bind,source=/home,target=/home,ro',
    *[
        '--mount=type=bind,source={},target={},ro'.format(d, d)
        for d in Path('/mnt').iterdir()
        if d.is_dir()
    ],
    '--mount=type=bind,source={},target={}'.format(PWD, PWD),
    '--workdir={}'.format(PWD),

    # Override image scripts with local bleeding edge ones
    f'--mount=type=bind,src={GIT_REPO_PATH/'bin'},dst=/vogeler/bin',
    f'--mount=type=bind,src={GIT_REPO_PATH/'lib'},dst=/vogeler/lib',
)


def print2(*args, **kwargs):
    print(*args, **kwargs, file=sys.stderr)


# Parse command line arguments
args = iter(sys.argv[1:])

script_name = Path(__file__).name
if script_name in ('gu', 'gis-utils'):
    try:
        exe = next(args)
    except StopIteration:
        print2(HELP)
        sys.exit(1)
else:
    # Assume filename of this script (symlink) is name of utility to call
    # in gis-utils container
    exe = script_name

exe_args = [*args]

# Run container
cmd = (
    'podman', 'run',
    *CON_ARGS,
    '--entrypoint={}'.format(exe),
    CON_IMG,
    *exe_args,
)
p = sp.run(cmd)
sys.exit(p.returncode)

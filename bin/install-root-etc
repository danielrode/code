#!/usr/bin/env python3
# author: daniel rode
# created: 12 jan 2026
# updated: 23 mar 2026


# Install system config files


import os
import sys
import subprocess as sp
from pathlib import Path


HOME = Path.home()
DRYRUN = False
try:
    if os.environ['dryrun'] == "true":
        DRYRUN = True
except KeyError:
    pass


print("WARNING: rsync will run as root")

# Install config files
args = [
    'sudo',
    'rsync',

    # Configure rsync information verbosity and format
    '--verbose',
    '--human-readable',
    '--itemize-changes',

    # Configure rsync data transfer method
    '--fsync',
    '--recursive',  # Copy source recursively
    '--perms', '--chmod=D755,F644',  # Set permissions
    '--chown=root:root',
    '--links',  # Copy symlinks as symlinks
    '--backup-dir=/etc/.trash',  # Keep backup of existing dest file
    '--mkpath',  # Create destination if it does not exist
    '--checksum',  # Copy file again even if size and times match dest
    '--omit-dir-times',
    '--omit-link-times',
]
if DRYRUN:
    args += [
        '--dry-run',
    ]
sp.run(
    args + [
        # Set source dest
        str(HOME / 'code/ins/system_etc') + '/',
        '/etc/',
    ],
    check=True,
)

# Fix permissions
if DRYRUN:
    sys.exit()
for perms in (
    ['0700', '/etc/ssh/sshd_config.d/'],
    ['0600', '/etc/ssh/sshd_config.d/99-harden.conf'],
):
    sp.run(['sudo', 'chmod'] + perms, check=True)

#!/usr/bin/env python3
# -*- coding: utf-8 -*-
# author: daniel rode
# dependencies: pastel
# created: 30 apr 2026


# Take the color(s) passed as arguments (hex color codes) and display colors
# that will work well with them in various contexts.


import sys
import subprocess as sp
from pathlib import Path


HELP_TEXT = f"Usage: {Path(__file__).name} COLOR..."


def print2(*args, **kwargs):
    print(*args, **kwargs, file=sys.stderr)

def run(cmd):
    sp.run(cmd, check=True)


args = sys.argv[1:]
src_colors = []
for a in args:
    src_colors += [a]


if len(src_colors) == 0:
    print(HELP_TEXT)
    sys.exit(1)

if len(src_colors) >= 2:
    print2("Fit good:")
    run(('pastel', 'mix', *src_colors))

if len(src_colors) >= 1:
    print2("Visually distinct:")
    run(('pastel', 'distinct', str(len(src_colors) + 1), *src_colors))

if len(src_colors) >= 1:
    print2("Complementary:")
    run(('pastel', 'complement' *src_colors))

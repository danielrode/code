#!/usr/bin/env bash
# author: daniel rode
# created: 10 jul 2025
# updated: 19 may 2026


# Print a given page range to a specific printer from a given PDF.
#
# NOTE: List available printer names
# lpstat -p
#
# NOTE: Cancel print jobs
# lprm -P PRINTER-NAME
#
# EXAMPLE (lp usage):
# lp -d Zebra-Technologies-ZTC-ZD421-203dpi-ZPL -o 4x3 -P "$pages" "$1"


printer_name="$1"
page_range="$2"
pdf_path="$3"
lp -d "$printer_name" -P "$page_range" "$pdf_path"

#!/usr/bin/env python3
# author: daniel rode
# dependencies:
#   sshfs (local)
#   dtach (on remote host)
#   ~/.nunyuh
# created: 23 feb 2025
# updated: 20 may 2026


# Alias/shortcuts for starting SSH sessions.


import sys
import shlex
import tomllib
import getpass
import subprocess as sp
from pathlib import Path


HOME = Path.home()
PWD = Path.cwd()
SSH_ARGS = [
    # Give up trying to connect if it takes too long
    '-o', 'ConnectionAttempts=64',
    '-o', 'ConnectTimeout=5',

    # Disconnect if server disappears for too long
    '-o', 'ServerAliveCountMax=4',
    '-o', 'ServerAliveInterval=11',
]
SSH_CMD = (
    # By using dtach, the user can simply close the terminal and it will
    # leave any program in the remote SSH shell running without killing it.
    'bash', '--login', '-c', f''':
        tmpdir="$(mktemp -d)"
        # Commenting out for now because Bash would remove socket file before
        # dtach was done with it if terminal closed, making it impossible to
        # connect to the socket later, even though the original dtach instance
        # was still using it.
        # function cleanup {{ rm -fr -- "$tmpdir"; }}
        # trap cleanup EXIT
        [[ -d {shlex.quote(str(PWD))} ]] && cd {shlex.quote(str(PWD))}
        dtach -c "$tmpdir/dtach.sock" -zE fish
    '''
)
NY = tomllib.loads(Path(HOME, ".nunyuh").read_text())['H']


def set_term_win_title(title):
    sys.stdout.write(f"\x1b]2;{title}\x07")
    sys.stdout.flush()


# Parse command line arguments
try:
    remote = sys.argv[1]
except IndexError:
    print("error: SSH remote host alias not provided")
    sys.exit(1)

# Set values for remote host
for k in NY:
    try:
        a = NY[k]['alias']
    except KeyError:
        a = None

    if (remote == k.lower()) or (remote == a):
        host = NY[k]
        break
else:
    print("error: Unknown alias:", remote)
    sys.exit(1)

del NY

use_sock = False
match remote:
    case 'h':
        use_sock = True
        SSH_CMD = ( 'bash', '--login', '-c', 'fish' )
    case 'p':
        SSH_CMD = ( 'bash', '--login', '-c', 'fish' )

try:
    ip = host['ip']
except KeyError:
    print("error: No address found for host:", remote)

try:
    title = host['title']
except KeyError:
    title = k.lower()

try:
    user = host['user']
except KeyError:
    user = getpass.getuser()

if use_sock:
    sock_path = Path(HOME, '.ssh', f"{user}@{ip}.sock")
    if not sock_path.exists():
        SSH_ARGS += [ '-M' ]  # Use "master" mode
    SSH_ARGS += [
        '-S', str(sock_path),
        # -f  # Authenticate, then run in background
        # -N  # Do not execute a remote command
        '-C'  # Compress all data
    ]

# Set terminal window title
set_term_win_title(title)

# Connect to remote host via SSH
print("Connecting...")
cmd = (
    'env', 'TERM=xterm',
    'ssh', '-t',
    *SSH_ARGS,
    '-l', user,
    ip,
    *SSH_CMD
)
sp.run(cmd)

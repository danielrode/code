#!/usr/bin/env python3
# author: daniel rode
# dependencies: ~/.nunyuh
# created: 25 jul 2024
# updated: 18 may 2026


# Alias/shortcuts for mounting remote directories via SSH.


import sys
import time
import socket
import tomllib
import getpass
import subprocess as sp
from pathlib import Path


# Constants
HOME = Path.home()
HOSTNAME = socket.gethostname()

NY = tomllib.loads(Path(HOME / '.nunyuh').read_text())['H']

SSHFS_ARGS = (
    '-o', 'delay_connect',
    '-o', 'reconnect',
    '-o', 'noatime',
    # '-o', 'umask=177',

    # Give up trying to connect if it takes too long
    '-o', 'ConnectionAttempts=3',
    '-o', 'ConnectTimeout=10',

    # Disconnect if server disappears for too long
    '-o', 'ServerAliveCountMax=4',
    '-o', 'ServerAliveInterval=11',
)


# Functions
def mountpoint(pth: Path) -> bool:
    pth = Path(pth)
    p = sp.run(['mountpoint', pth])
    if p.returncode == 0:
        return True  # pth is a mount point
    elif p.returncode == 32:
        return False  # pth is not a mount point
    else:
        raise Exception("mountpoint gave unexpected exit code:", p.returncode)

def sshfs(
    mnt_point: Path,
    sshfs_args: list,
    remote_user: str,
    remote_addr: str,
    remote_dir: Path
) -> None:
    if mountpoint(mnt_point):
        print("Already mounted:", mnt_point)
        return

    cmd = (
        'sshfs', *sshfs_args,
        f"{remote_user}@{remote_addr}:{remote_dir}",
        mnt_point,
    )
    sp.run(cmd, check=True)


# Parse command line input
try:
    remote = sys.argv[1]
except IndexError:
    print("Enter mount point")
    sys.exit(1)

# Set values for remote host
for k in NY:
    try:
        a = NY[k]['alias']
    except KeyError:
        a = None

    if (remote == k.lower()) or (remote == a):
        host = NY[k]
        break
else:
    print("error: Unknown alias:", remote)
    sys.exit(1)

del NY

mnt_list = None
use_sock = False
match remote:
    case 'h':
        use_sock = True
        SSH_CMD = ( 'bash', '--login' )

mnt_list = host['mounts']
ip = host['ip']

try:
    user = host['user']
except KeyError:
    user = getpass.getuser()

# Setup master SSH connection (if requested)
if use_sock:
    sock_path = HOME / f'.ssh/{user}@{ip}.sock'
    SSHFS_ARGS += (
        # TODO should I shlex.quote the sock_path here?
        '-o', f'ssh_command=ssh -S {sock_path}',
    )
    # Wait for master SSH connection to be established by user
    while not sock_path.exists():
        print("Waiting for user to establish SSH session via `s`...")
        time.sleep(5)

# Mount
for remote_dir, mount_point in mnt_list:
    sshfs(mount_point, SSHFS_ARGS, user, ip, remote_dir)

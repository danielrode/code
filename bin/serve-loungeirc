#!/usr/bin/env bash
# author: daniel rode
# created: 10 may 2025
# updated: 24 may 2026


# Run IRC client.


# DOC (setup):
# sudo loginctl enable-linger $(whoami)
#
# DOC (add IRC user):
# podman exec --user node -it loungeirc thelounge add MrLiDAR


DATA_DIR="$HOME/.appdata/loungeirc"


mkdir -p "$DATA_DIR"
args=(
    --name loungeirc --replace
    --publish 9000:9000
    --tz=local
    --volume "$DATA_DIR":/var/opt/thelounge:z
    # --restart always # nah, systemd will restart it
    ghcr.io/thelounge/thelounge:latest
)
podman run "${args[@]}"

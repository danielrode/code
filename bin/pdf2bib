#!/usr/bin/env python3
# author: daniel rode
# dependencies: ghostscript, podman
# created: 11 may 2026
# updated: 12 may 2026


# TODO
exit(1)

# Get and print BibTeX entry for a given PDF article.


import sys
import time
import subprocess as sp
from pathlib import Path
from tempfile import TemporaryDirectory

import yaml


# Constants
EXE_NAME = Path(__file__).name

PY_PAYLOAD = r"""
import sys
import time
import json
from pathlib import Path
from tempfile import TemporaryDirectory

from grobid_tei_xml import parse_document_xml
from grobid_client.grobid_client import GrobidClient

def teixml2bib(biblio, entry_id="paper_cite"):
    if not biblio:
        return ""

    author_list = " and ".join([
        a.full_name
        for a in biblio.authors
        if a.full_name
    ])

    fields = {
        "title": biblio.title,
        "author": author_list,
        "year": biblio.date,
        "journal": biblio.journal or biblio.book_title,
        "volume": biblio.volume,
        "number": biblio.issue,
        "doi": biblio.doi,
        "publisher": biblio.publisher
    }
    if biblio.first_page and (biblio.last_page or biblio.pages):
        len_pg = biblio.last_page
        if not len_pg:
            len_pg = biblio.pages
        fields["pages"] = f"{biblio.first_page}--{len_pg}"

    entry_type = "article"  # TODO what if book or website or ...
    bib_str = "@"
    bib_str += entry_type
    bib_str += '{'
    bib_str += biblio.authors[0].surname.lower() + str(biblio.date.year)
    bib_str += r',\n'
    for k, v in fields.items():
        if v:
            bib_str += k
            bib_str += '={'
            bib_str += v
            bib_str += r'},\n'
    
    return bib_str

cfg_fp = Path("/tmp/grobid-client-conf.json")
cfg_fp.write_text(json.dumps({
    "grobid_server": "http://server:8070",
    "batch_size": 512,
    "sleep_time": 2,
    "timeout": 4,
    "coordinates": [
        "persName",
        "figure",
        "ref",
        "biblStruct",
        "formula",
        "s",
    ],
}))

for _ in range(64*4):  # Try for 64 seconds
    try:
        client = GrobidClient(config_path=str(cfg_fp))
        client.process(
            "processHeaderDocument",
            "/in",
            output="/out",
            force=True,
        )
    except Exception as e:
        print(e)
        time.sleep(1/4)
        continue
    break

out_blob = ""
for i in Path("/out").glob('*.tei.xml'):
    doc = parse_document_xml(i.read_text())
    out_blob += '\n'
    out_blob += teixml2bib(doc.header)

Path("/out/cit.bib").write_text(out_blob)
"""

CON_SERVICES = {
    'server': {
        'image': 'grobid/grobid:0.9.0-crf',
        # 'ports': ['8070:8070'],
        'restart': 'never',
    },
    'client': {
        'image': 'grobid-client-python',
        'command': [
            'sh', '-c',
            '''python3 <<'EOF'\n{}\nEOF'''.format(PY_PAYLOAD),
        ],
        'volumes': [],
        'depends_on': ['server'],
        'restart': 'never',
    },
}
CON_COMPOSE = {
    'name': EXE_NAME,
    'services': CON_SERVICES,
}

DOCKERFILE = '''
FROM docker.io/python:alpine
RUN pip install --no-cache-dir grobid-client-python grobid-tei-xml
'''


# Functions
def print2(*args, **kwargs):
    print(*args, **kwargs, file=sys.stderr)


# Parse command line arguments
src_pdfs = [Path(i) for i in sys.argv[1:]]
for i in src_pdfs:
    if not i.exists():
        print2("error: Path not found:", i)
        sys.exit(1)

if not src_pdfs:
    print2("error: No path provided")
    sys.exit(1)

# Build image with grobid/Python bindings exists (if necessary)
cmd = ('podman', 'inspect', 'grobid-client-python')
try:
    sp.run(cmd, check=True, stdout=sp.DEVNULL, stderr=sp.DEVNULL)
except sp.CalledProcessError:
    cmd = (
        'podman', 'build',
        '--file=-',
        '--tag=grobid-client-python',
    )
    sp.run(cmd,
        check=True,
        text=True,
        input=DOCKERFILE,
        stdout=sys.stderr,
    )

# Run containers
with TemporaryDirectory() as td:
    td = Path(td)
    td.chmod(0o755)
    compose_fp = td / 'compose.yml'
    td_out = td / 'out'
    td_out.mkdir()
    CON_SERVICES['client']['volumes'] += ['{}:/out'.format(td_out)]
    CON_SERVICES['client']['volumes'] += [
        '{}:/in/{}:ro'.format(i.resolve(), i.name)
        for i in src_pdfs
    ]
    compose_yaml = yaml.dump(CON_COMPOSE)
    compose_fp.write_text(compose_yaml)
    cmd = (
        'podman-compose',
        '--file={}'.format(compose_fp),
        'up',
    )
    p = sp.Popen(cmd, stdout=sys.stderr)
    try:
        while True:
            time.sleep(0.1)
            if Path(td_out, 'cit.bib').exists():
                break
        print(Path(td_out, 'cit.bib').read_text())
    except KeyboardInterrupt:
        pass
    cmd = (
        'podman-compose',
        '--file=-',
        'down',
    )
    sp.run(cmd, text=True, input=compose_yaml, stdout=sys.stderr)
    sys.exit(0)

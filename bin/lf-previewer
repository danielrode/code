#!/usr/bin/env sh
# author: daniel rode
# dependencies: unzip, 7z, pdftotext, GraphicsMagick, chafa
# created: 20 apr 2026
# updated: 26 apr 2026


# Generate preview for LF preview pane for given (highlighted) file.


# DOC (from LF man):
# The following arguments are passed to the file by lf, (1) current
# filename, (2) width, (3) height, (4) horizontal position, (5) vertical
# position, and (6) mode ("preview" or "preload"). The output of this
# script is printed in the LF preview pane.


case "$(file -bL --mime-type "$1")" in
	text/*|application/json|application/x-ndjson)
		strings -aw -n 1 -U x "$1";;
	application/x-tar|application/gzip)
		tar tf "$1";;
	application/x-7z-compressed|application/zip)
		7z l "$1";;
	application/pdf)
		pdftotext "$1" -;;
	image/png|image/jpeg|image/gif)
		chafa --format=symbols --polite=on --align=top,left "$1";;
	image/tiff|image/webp)
		gm convert "$1" jpg:- | \
			chafa --format=symbols --polite=on --align=top,left
		;;
	application/*)
		echo "binary";;
	inode/x-empty)
		echo "empty file";;
	*)
		echo "no preview";;
esac

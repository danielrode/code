#!/usr/bin/env python3
# author: daniel rode
# dependencies: python 3.10+, img2pdf
# created: 24 jun 2026


import sys
import subprocess as sp
from pathlib import Path


EXE_NAME = Path(__file__).name  # This script's filename
HELP = f"Usage: {EXE_NAME} SRC_PNG... DST_PDF"


def print2(*args, **kwargs):
    print(*args, **kwargs, file=sys.stderr)


# Main
args = sys.argv[1:]
if len(args) < 2:
    print2(HELP)
    sys.exit(1)

dst_pdf = Path(args[-1])
if dst_pdf.suffix.lower() != '.pdf':
    print2("Destination path does not have PDF filename extension")
    sys.exit(1)

src_pngs = args[:-1]

p = sp.run((
    'img2pdf',
    *(str(i) for i in src_pngs),
    '-o', str(dst_pdf),
))
sys.exit(p.returncode)

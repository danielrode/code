#!/usr/bin/env bash
# author: daniel rode
# dependencies: fd
# created: 18 mar 2026
# updated: -


# Install a given directory to a given destination.
#
# Executes `install` in such a way that SRC_DIR  -->  DST_DIR/SRC_DIR


HELP="Usage: installd SRC_DIR DST_DIR"
SRC_DIR="$1"
DST_DIR="$2"

if [[ ! -d "$SRC_DIR" ]]
then
    echo "$HELP"
    exit 1
fi
if [[ -f "$DST_DIR" ]]
then
    echo "$HELP"
    exit 1
fi

cd "$(dirname "$1")"
fd -0 --type file . "$SRC_DIR" \
| xargs -0 -I@ install -D -m 0655 @ "$DST_DIR/@"



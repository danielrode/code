#!/usr/bin/env bash
# author: daniel rode
# dependencies:
#   fd (fd-find)
#   xxd
# created: 11 aug 2023
# updated: 23 may 2026


# Remove empty files. Delete all empty files in the given directory. If no
# directory is specified, the current directory is processed. Files that merely
# consist of one newline character are also considered "empty" (and thus
# removed).


# Delete empty files
fd --print0 --exact-depth=1 --type=empty . "$1" \
| xargs --null --no-run-if-empty rm --verbose

# Delete files only containing one newline character
fd --exact-depth=1 --type=file --size=-1b . "$1" | while read path; do
    [[ "$(xxd --plain <"$path")" == "0a" ]] && rm -v "$path"
done

#   ~/code/bin/wconnect
#   ~/.nunyuh
# created: 01 apr 2026
# updated: 18 may 2026


"""Connect to mobile hotspot.
"""


import tomllib
import subprocess as sp
from pathlib import Path


HOME = Path.home()
NY = tomllib.loads(Path(HOME, '.nunyuh').read_text())['H']['PHONE']


cmd = (
    str(HOME / 'code/bin/wconnect'),
    'w',
    NY['hotspot_name'],
)
sp.run(cmd, check=True)

#!/usr/bin/env python3
# author: daniel rode
# dependencies: fzf
# created: 12 may 2026
# updated: 08 jun 2026


# List available templates, and then copy to destination.


import sys
import shlex
import subprocess as sp
from pathlib import Path


PWD = Path.cwd()
HOME = Path.home()
PY_PREVIEW_CODE_PAYLOAD = """
from sys import argv
from subprocess import run
from pathlib import Path
fp = Path(argv[1])
if fp.is_dir():
    run(['tree', str(fp)])
else:
    run(['cat', str(fp)])
"""


# Parse command line arguments
try:
    dst = Path(sys.argv[1])
except IndexError:
    dst = PWD
dst = str(dst) + '/'

# Find available templates
tems = [str(i) for i in Path(HOME, 'code', 'tem').iterdir()]

# User select template of interest
cmd = (
    'fzf',
    '--delimiter=/',
    '--with-nth=-1',
    f'--preview=python3 -c {shlex.quote(PY_PREVIEW_CODE_PAYLOAD)} {{}}',
    '--preview-window=up,50%',
)
p = sp.run(
    cmd,
    text=True,
    input='\n'.join(tems),
    stdout=sp.PIPE,
)
sel = p.stdout.strip()
if not sel:
    print("No selection made")
    sys.exit(0)

# Clone selected template
cmd = (
    'rsync',
    '--verbose',
    '--human-readable',
    '--itemize-changes',
    '--recursive',
    '--copy-links',
    '--keep-dirlinks',
    '--perms',
    '--executability',
    '--ignore-existing',
    '--partial',
    '--mkpath',
    str(sel),
    str(dst),
)
sp.run(cmd, check=True)

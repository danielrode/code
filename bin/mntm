#!/usr/bin/env python3
# author: daniel rode
# name: mount menu
# dependencies:
#   udisks2
#   lf
# created: 12 apr 2020
# updated: 22 may 2026


import io
import sys
import csv
import json
import subprocess as sp
from pathlib import Path


HOME = Path.home()


def print2(*args, **kwargs) -> None:
    print(*args, **kwargs, file=sys.stderr)


def lsblk() -> None:
    cmd = (
        'lsblk',
        '--output',
        'NAME,FSTYPE,SIZE,FSUSE%,LABEL,MOUNTPOINTS',
        '--list',
        '--paths',
        '--json',
    )
    p = sp.run(cmd, check=True, capture_output=True, text=True)

    return json.loads(p.stdout)['blockdevices']


def lsblk_json2csv(lsblk_json: list[dict]) -> str:
    with io.StringIO() as f:
        writer = csv.DictWriter(
            f,
            fieldnames=parts[0].keys(),
            lineterminator='\n',
        )
        writer.writeheader()
        writer.writerows(parts)

        return f.getvalue()


def csv2fixed(csv: str) -> str:
    """Convert a CSV to fixed-width text format."""
    cmd = (
        'column',
        '--table',
        '--separator', ',',
    )
    p = sp.run(cmd, check=True, text=True, capture_output=True, input=csv)

    return p.stdout


def udisksctl(part_path: Path, ro=False) -> (str, str):
    cmd = [
        'udisksctl', 'mount',
    ]
    if ro:
        cmd += ['--options=ro']
    cmd += ['--block-device', str(part_path)]

    p = sp.run(cmd, check=True, capture_output=True, text=True)
    print2(p.stdout)

    blk_dev, mnt_point, = (
        p
        .stdout
        .strip()
        .lstrip("Mounted ")
        .split(' at ', maxsplit=1)
    )

    return blk_dev, mnt_point


# Parse command line arguments
read_only_mode = False
for a in iter(sys.argv[1:]):
    match sys.argv[1]:
        case '--ro' | 'ro' | '-r':
            read_only_mode = True
        case _:
            print2("error: Invalid option:", a)
            sys.exit(1)

if read_only_mode:
    print2("Read-only mode ACTIVE!")

# Get list of partitions
parts = lsblk()
parts = list(filter(
    # Filter out /dev/ paths that are not partitions
    lambda x: x['fstype'] is not None,
    parts,
))

parts_csv = lsblk_json2csv(parts)
parts_fw = csv2fixed(parts_csv)

# Get user selections for which partition(s) to mount
cmd = (
    'fzf',
    # '--multi',
    '--header-lines', '1',
    '--bind', 'f5:become(mntm)',
    '--header', 'Press F5 to refresh the list',
)
p = sp.run(cmd, text=True, stdout=sp.PIPE, input=parts_fw)

if not p.stdout:
    print2("No selection made")
    sys.exit(0)

# Mount partition
part_path = [i.split(' ')[0] for i in p.stdout.strip().split('\n')][0]
_, mnt_point = udisksctl(part_path, ro=read_only_mode)

# Open mounted partition in file manager
sp.run(["lf", mnt_point])  # todo use ccarousel

# Unmount partition
sp.run(['umount', mnt_point], check=True)
print2("Unmounted:", mnt_point)

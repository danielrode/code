#!/usr/bin/env bash
# author: daniel rode
# dependencies:
#   dtach
# created: 19 feb 2026
# updated: 26 mar 2026


# Start a new dtach session.


tmpdir="$(mktemp -d)"
# Commenting out for now because Bash would remove socket file before
# dtach was done with it if terminal closed, making it impossible to
# connect to the socket later, even though the original dtach instance
# was still using it.
# function cleanup { rm -rf -- "$tmpdir"; }
# trap cleanup EXIT

dtach -c "$tmpdir/dtach.sock" -Ez fish

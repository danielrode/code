#!/usr/bin/env python3
# author: daniel rode
# dependencies: podman, podman-compose, crun-krun, ~/.nunyuh
# created: 12 apr 2026
# updated: 14 jun 2026


# TODO


# Run containerized Joplin (notes) server.

# NOTE:
# Joplin server's default username and pw: "admin@localhost", "admin"
# Change these first thing!


import sys
import signal
import tomllib
import subprocess as sp
from pathlib import Path
from tempfile import TemporaryDirectory

import yaml


APP_NAME = 'joplin'

HOME = Path.home()

NY = tomllib.loads(Path(HOME, '.nunyuh').read_text())['S'][APP_NAME]

CON_HARDENED_DEFAULTS = {
    'runtime': '/usr/bin/krun',
    'cap_drop': ['ALL'],
    'security_opt': ['no-new-privileges'],
    'read_only': True,
    'tmpfs': ['/tmp:rw,noexec,nosuid,nodev,mode=1700'],
    
}
CON_SERVICES = {
    'rathole': {
        **CON_HARDENED_DEFAULTS,
        'image': 'docker.io/rapiz1/rathole:latest',
        'container_name': f'{APP_NAME}_rathole',
        # 'volumes': [
        #     '~/rathole.toml:/rh.toml:ro,U,Z', # todo
        # ],
        'command': '/rh.toml',  # todo use podman secrets?
        'restart': 'always',
        'deploy': { 'resources': { 'limits': {
            # Limit memory usage
            'mem_limit': '128m',
            # Limit CPU usage to 50% of a single core
            'cpus': 0.5,
        }}},
        'user': '1111:1111',
    },
    'db': {
        **CON_HARDENED_DEFAULTS,
        'image': 'docker.io/postgres:16',
        'container_name': f'{APP_NAME}_db',
        'volumes': [
            {
                'type': 'volume',
                'source': 'postgres',
                'target': '/var/lib/postgresql/data',
                'volume': {
                    'U': True,
                    'mode': 0o700,
                },
            },
            # 'postgres:/var/lib/postgresql/data:U',
        ],
        'environment': [
            'POSTGRES_PASSWORD=${DB_PW}',
            'POSTGRES_USER=joplin0',
            'POSTGRES_DB=joplindb',
        ],
        'restart': 'always',
        'deploy': { 'resources': { 'limits': {
            # Limit memory usage
            'mem_limit': '256m',
            # Limit CPU usage to 50% of a single core
            'cpus': 0.5,
        }}},
        'user': '999:999',
    },
    'joplin': {
        **CON_HARDENED_DEFAULTS,
        'image': 'docker.io/joplin/server:latest',
        'container_name': f'{APP_NAME}_server',
        'depends_on': ['db'],
        'environment': [
            'APP_PORT=22300',  #todo
            'APP_BASE_URL=${APP_BASE_URL}',
            'DB_CLIENT=pg',
            'POSTGRES_PASSWORD=${DB_PW}',
            'POSTGRES_DATABASE=joplindb',
            'POSTGRES_USER=joplin0',
            'POSTGRES_PORT=5432',
            'POSTGRES_HOST=db',
        ],
        'restart': 'always',
        'deploy': { 'resources': { 'limits': {
            # Limit memory usage
            'mem_limit': '256m',
            # Limit CPU usage to 50% of a single core
            'cpus': 0.5,
        }}},
        'user': '1111:1111',
    },
}
CON_COMPOSE = {
    'name': APP_NAME,
    'services': CON_SERVICES,
    'volumes': {
        'postgres': {
            'name': f'{APP_NAME}_postgres',
        },
    },
    'version': '3',
}

PODMAN_CMD = (
    'podman-compose',
    '--no-ansi',
    '--podman-pull-args=--pull=missing',
    '--project-name=' + APP_NAME,
)


# Main
with TemporaryDirectory(ignore_cleanup_errors=True) as td:
    env_fp = Path(td, 'compose.env')
    env_fp.touch(mode=0o600)
    env_fp.write_text('\n'.join((
        'DB_PW=' + NY['db_pw'],
        'APP_BASE_URL' + NY['origin'],
    )))

    cmd = (
        *PODMAN_CMD,
        '--env-file=' + str(env_fp),
        '--file=-',
        'up',
    )
    signal.signal(signal.SIGINT, signal.SIG_IGN)  # Ignore Ctrl+C
    p = sp.run(cmd, input=yaml.dump(CON_COMPOSE), text=True)

sys.exit(p.returncode)

#!/usr/bin/env python3
# author: daniel rode
# created: 07 may 2026


# Run xargs on stdin lines.. If '@' is provided in command string in the
# command line arguments to this script. it will be # replaced with input
# args provided via stdin.


import sys
import subprocess as sp


cmd = [
    'xargs',
    '--delimiter=\n',
]
if any('@' in i for i in sys.argv[1:]):
    cmd += ['--replace=@']
cmd += sys.argv[1:]

sp.run(cmd, check=True, stdin=sys.stdin)

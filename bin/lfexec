#!/usr/bin/env bash
# author: daniel rode
# dependencies: lf, fish
# created: 25 mar 2026
# updated: -


# Run lf file manager, and ensure it always exits to a fish shell, and that
# fish changes directory to where lf was.

# Inspired by https://github.com/gokcehan/lf/blob/master/etc/lfcd.fish


cd "$(lf -print-last-dir "$@")"
exec /usr/bin/fish

# For when loading Sway via GDM (since that start method does not read vars
# from ~/.profile and my sway launch script) and also for when loading Sway
# via ~/.profile since that script will load vars from this file.
#
# File format:
# https://www.freedesktop.org/software/systemd/man/latest/environment.d.html


VISUAL=hx
EDITOR="$VISUAL"
PAGER=less
DEFAULT_TERM=foot

# Color 777 orange
LS_COLORS="${LS_COLORS}:ow=01;33"

# Constants for ~/code
DCV_CODE_PATH="$HOME/code"
DCV_HOME_OPT="$HOME/.local/opt"

# XDG
XDG_CONFIG_HOME="$HOME/.config"
XDG_CACHE_HOME="$HOME/.cache"
XDG_DATA_HOME="$HOME/.local/share"
XDG_DESKTOP_DIR="$HOME/working"
XDG_DOCUMENTS_DIR="$HOME/progeny"
XDG_DOWNLOAD_DIR="$HOME/downloads"
XDG_MUSIC_DIR="$HOME/store/music"
XDG_PICTURES_DIR="$HOME/media"
XDG_VIDEOS_DIR="$HOME/media"
XDG_TEMPLATES_DIR="$HOME/code/tem"
XDG_PUBLICSHARE_DIR="$HOME/union/public"
XDG_SCREENSHOTS_DIR="$XDG_PICTURES_DIR/screencaptures/current"

# Path
PATH="$PATH:/opt/bin"
PATH="$PATH:$HOME/.local/bin"
PATH="$PATH:$DCV_CODE_PATH/bin"
PATH="$PATH:$DCV_HOME_OPT/bin"
PATH="$PATH:$HOME/.cargo/bin"

GOPATH="$HOME/.appdata/go"
PATH="$PATH:$GOPATH/bin"

# GTK/QT
QT_QPA_PLATFORMTHEME="gtk3"

# Program Config
LESS="--RAW-CONTROL-CHARS --ignore-case --jump-target=.3 --mouse -XFn"
LESSEDIT="%E < %f"

BAT_PAGER="$PAGER"

R_LIBS_USER="$HOME/.local/lib/R"

~/code/bin/latest-screenshot  # View Latest Screenshots
~/code/bin/sway-pick-color  # Color Picker
wl-paste | ~/code/bin/strip-newline | wl-copy  # Clipboard Strip Newline
bluetoothctl power off  # Turn off Bluetooth
pactl set-sink-mute '@DEFAULT_SINK@' toggle  # Toggle mute/unmute
qrgen "$(wl-paste | ~/code/bin/strip-newline)"  # Display clipboard contents as qrcode
kmonad ~/code/etc/kmonad/colemak2qwerty.kbd  # Keyboard Layout: Qwerty (qwfpgj)
pkill kmonad  # Keyboard Layout: Colemak (c;ukman)
foot ~/code/bin/sway-rename-workspace  # Sway: Rename Workspace
wl-paste | ~/code/bin/mutate unwrap | wl-copy --trim-newline  # Flatten Clibpoard Text
wl-paste | ~/code/bin/mutate title | wl-copy --trim-newline  # Title-Case Clipboard Text

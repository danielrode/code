# Unpack a .tar.gz archive.


import sys
import subprocess as sp
from pathlib import Path


src = Path(sys.argv[1])
try:
    dst = Path(sys.argv[2])
except IndexError:
    dst = Path(src.parent, src.name.lower().removesuffix(".tar.gz"))

if not src.name.lower().endswith(".tar.gz"):
    print("error:Invalid filetype")
    sys.exit(1)

dst.mkdir(exist_ok=True)

cmd = (
    'tar',
    '-xzvf',
    str(src),
    '-C', str(dst),
)
p = sp.run(cmd)

sys.exit(p.returncode)

#!/usr/bin/env python3
# author: daniel rode
# created: 10 jul 2025
# updated: 23 may 2026


# Print a given page range to a specific printer from a given PDF.
#
# NOTE: List available printer names
# lpstat -p
#
# NOTE: Cancel print jobs
# lprm -P PRINTER-NAME
#
# EXAMPLE (lp usage):
# lp -d Zebra-Technologies-ZTC-ZD421-203dpi-ZPL -o 4x3 -P "$pages" "$1"


import sys
import subprocess as sp
from pathlib import Path


EXE_NAME = Path(__file__).name
HELP_TEXT = f"Usage: {EXE_NAME} PRINTER PDF [PAGE_RANGE]"


try:
    printer_name, pdf_fp = sys.argv[1:3]
except ValueError:
    print(HELP_TEXT)
    sys.exit(1)

try:
    page_range = sys.argv[3]
except IndexError:
    page_range = None

pdf_fp = Path(pdf_fp)

cmd = [
    'lp',
    '-d', printer_name,
]
if page_range:
    cmd += ['-P', page_range]
cmd += [str(pdf_fp)]
p = sp.run(cmd)
sys.exit(p.returncode)

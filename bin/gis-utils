#!/usr/bin/env python3
# author: daniel rode
# dependencies: podman
# created: 21 jul 2025
# updated: 09 apr 2026


import sys
import subprocess as sp
from pathlib import Path

# TODO error if mount mounted with 'readonly' flag has sub-mounts (as podman will make them rw by default)


HELP_TEXT = "Usage: gis-utils UTILITY_NAME [ARGS...]"
PWD = Path.cwd()
CON_IMG = 'ghcr.io/danielrode/gis-utils:dev'
CON_ARGS = (
    '--rm',
    '--tty',
    '--interactive',
    '--mount=type=bind,source=/tmp,target=/tmp',
    '--mount=type=bind,source=/home,target=/home,readonly',
    *[
        '--mount=type=bind,source={},target={},readonly'.format(d, d)
        for d in Path('/mnt').iterdir()
        if d.is_dir()
    ],
    '--mount=type=bind,source={},target={}'.format(PWD, PWD),
    '--workdir={}'.format(PWD),
    CON_IMG,
)


# Parse command line arguments
exe = Path(sys.argv[0]).name
if exe in ('git-utils', 'gu'):
    try:
        exe = Path(sys.argv[1]).name
    except IndexError:
        print(HELP_TEXT)
        exit(1)
    args = sys.argv[2:]
else:
    args = sys.argv[1:]

# Run container
cmd = (
    'podman', 'run',
    *CON_ARGS,
    exe,
    *args,
)
p = sp.run(cmd)
sys.exit(p.returncode)

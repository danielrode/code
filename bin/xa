#!/usr/bin/env python3
# author: daniel rode
# created: 07 may 2026
# updated: 05 jun 2026


# Run xargs on stdin lines. If '@' is provided in command string in the
# command line arguments to this script. it will be replaced with input
# args provided via stdin.


import sys
import subprocess as sp


# Setup xargs command arguments
cmd = [
    'xargs',
    '--null',
]
if any('{}' in i for i in sys.argv[1:]):
    cmd += ['--replace={}']
elif any('@' in i for i in sys.argv[1:]):
    cmd += ['--replace=@']
cmd += sys.argv[1:]

# Start xargs
p = sp.Popen(cmd, stdin=sp.PIPE, text=True)

# Pass stdin to xargs line-by-line, replacing newline with null character along
# the way and omitting empty lines
for line in sys.stdin.readlines():
    line = line[:-1]
    if not line:
        continue

    p.stdin.write(line)
    p.stdin.write('\0')
    p.stdin.flush()

if p.stdin:
    p.stdin.close()
p.wait()

sys.exit(p.returncode)

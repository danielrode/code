#!/usr/bin/env python3
# author: daniel rode
# created: 25 jul 2024
# updated: 26 mar 2026


# Alias/shortcuts for mounting remote directories via SSH.


import sys
import time
import socket
import tomllib
import getpass
import subprocess as sp
from pathlib import Path


# Constants
HOSTNAME = socket.gethostname()
HOME = Path.home()

SSHFS_ARGS = (
    '-o', 'delay_connect',
    '-o', 'reconnect',
    '-o', 'noatime',
    # '-o', 'umask=177',

    # Give up trying to connect if it takes too long
    '-o', 'ConnectionAttempts=3',
    '-o', 'ConnectTimeout=10',

    # Disconnect if server disappears for too long
    '-o', 'ServerAliveCountMax=4',
    '-o', 'ServerAliveInterval=11',
)

with open(HOME / '.crypt/private_code_vars.toml', 'rb') as f:
    VARS = tomllib.load(f)


# Functions
def mountpoint(pth: Path) -> bool:
    pth = Path(pth)
    p = sp.run(['mountpoint', pth])
    if p.returncode == 0:
        return True  # pth is a mount point
    elif p.returncode == 32:
        return False  # pth is not a mount point
    else:
        raise Exception("mountpoint gave unexpected exit code:", p.returncode)

def sshfs(
    mnt_point: Path,
    sshfs_args: list,
    remote_user: str,
    remote_addr: str,
    remote_dir: Path
) -> None:
    if mountpoint(mnt_point):
        print("Already mounted:", mnt_point)
        return

    cmd = (
        'sshfs', *sshfs_args,
        f"{remote_user}@{remote_addr}:{remote_dir}",
        mnt_point,
    )
    sp.run(cmd, check=True)


# Parse command line input
try:
    alias = sys.argv[1]
except IndexError:
    print("Enter mount point")
    sys.exit(1)

# Import and set remote host connection attributes
with open(HOME / '.crypt/private_code_vars.toml', 'rb') as f:
    private_code_vars = tomllib.load(f)

mnt_list = None
use_sock = False
match alias:
    case 's':
        host = "HOME_SERVER"
        mnt_list = (('/', '/mnt/s'),)
    case 'm':
        host = "WORK1"
    case 'h':
        host = "WORK2"
        use_sock = True
        SSH_CMD = ( 'bash', '--login' )
    case _:
        print("error: Unknown mount alias:", alias)
        sys.exit(1)

if mnt_list is None:
    mnt_list = private_code_vars[host]['mounts']

try:
    user = private_code_vars[host]['user']
except KeyError:
    user = getpass.getuser()

try:
    ip = VARS[host]["ip"]
except KeyError:
    ip = VARS[host]['ip_part1'] + sys.argv[2] + VARS[host]["ip_part2"]

if use_sock:
    sock_path = HOME / f'.ssh/{user}@{ip}.sock'
    SSHFS_ARGS += (
        # TODO should I shlex.quote the sock_path here?
        '-o', f'ssh_command=ssh -S {sock_path}',
    )
    # Wait for master SSH connection to be established by user
    while not sock_path.exists():
        print("Waiting for user to establish SSH session via `s`...")
        time.sleep(5)

# Mount
for remote_dir, mount_point in mnt_list:
    sshfs(mount_point, SSHFS_ARGS, user, ip, remote_dir)

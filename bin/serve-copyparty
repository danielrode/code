#!/usr/bin/env python3
# author: daniel rode
# dependencies: podman, podman-compose, ~/.nunyuh
# created: 15 may 2026
# updated: 24 may 2026


# Run copyparty server.


import os
import sys
import tomllib
import subprocess as sp
from pathlib import Path

import yaml


APP_NAME = 'copyparty'

HOME = Path.home()
CFG_DIR = Path(
    HOME,
    '.config',
    'com.github.danielrode',
    APP_NAME,
)

CON_IMG = 'ghcr.io/9001/copyparty-ac:latest'
CON_PORT = 3923
CON_SERVICES = {
    'copyparty': {
        'image': CON_IMG,
        'ports': ['{}:{}'.format(CON_PORT, CON_PORT)],
        'volumes': [
            '{}/copyparty_bucket:/w:z'.format(HOME),
            '{}:/cfg:z'.format(CFG_DIR),
            '/etc/localtime:/etc/localtime:ro',
        ],
        'restart': 'always',
        'stop_grace_period': '15s',  # Give thumbnailer time to finish
        'userns_mode': 'keep-id',
        'user': '{}:{}'.format(os.getuid(), os.getgid()),
        # TODO test that the following is not too restrictive
        'cap_drop': ['ALL'],
        'security_opt': ['no-new-privileges'],
        'read_only': True,
        'tmpfs': ['/tmp:rw,noexec,nosuid,nodev,mode=1700'],
        'deploy': {'resources': {'limits': {
            'mem_limit': '256m',  # Limit memory to 256MB
            'cpus': 1,  # Limit CPU usage to 100% of a single core
        }}},
    },
}
CON_COMPOSE = {
    'name': 'copyparty',
    'services': CON_SERVICES,
}

PODMAN_CMD = (
    'podman-compose',
    '--no-ansi',
    '--podman-pull-args=--pull=missing',
    '--project-name=' + APP_NAME,
    '--file=-',
)


# Install default config file if none found
cfg_fp = CFG_DIR / "main.conf"
if not cfg_fp.exists():
    CFG_DIR.mkdir(exist_ok=True, parents=True, mode=0o700)
    ny = tomllib.loads((HOME / '.nunyuh').read_text())['S']['copyparty']
    cfg_fp.write_text(ny)

# Update copyparty, if needed
cmd = ('podman', 'pull', '--policy=newer', CON_IMG)
sp.run(cmd, check=True)

# Run copyparty
try:
    sp.run(
        [*PODMAN_CMD, 'up'],
        input=yaml.dump(CON_COMPOSE),
        text=True,
        check=True,
    )
except KeyboardInterrupt:
    pass
sp.run(
    [*PODMAN_CMD, 'down'],
    input=yaml.dump(CON_COMPOSE),
    text=True,
)

sys.exit(0)

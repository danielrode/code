#!/usr/bin/env python3
# author: daniel rode
# dependencies: podman, podman-compose, ~/.nunyuh
# created: 24 may 2026


# Run memos server.
#
# https://github.com/usememos/memos


import os
import sys
import subprocess as sp
from pathlib import Path


APP_NAME = 'memos'

HOME = Path.home()
DATA_DIR = Path(
    HOME,
    '.appdata',
    APP_NAME,
)

CON_IMG = 'docker.io/neosmemo/memos:stable'
PORT = 5230
PODMAN_CMD = [
    'podman', 'run',
    '--name={}'.format(APP_NAME),
    '--replace',
    '--publish={}:{}'.format(PORT, PORT),
    '--volume={HOME}/.appdata/memos:/var/opt/memos:z'.format(HOME=HOME),
    '--userns=keep-id',
    '--user={}:{}'.format(os.getuid(), os.getgid()),
    '--tz=local',
    '--pull=never',

    # Harden
    '--security-opt=no-new-privileges',
    '--security-opt=proc-opts=hidepid=2',
    '--cap-drop=ALL',
    '--read-only',
    '--read-only-tmpfs',
    '--tmpfs=/tmp:rw,noexec,nosuid,nodev,mode=1700',

    CON_IMG,
]
p = sp.run(PODMAN_CMD)
sys.exit(p.returncode)

#!/usr/bin/env python3
# author: daniel rode
# dependencies:
#   freerdp
#   ~/.crypt/private_code_vars.toml
# created: 15 jul 2025
# updated: 26 mar 2026


# Alias/shortcuts for starting RDP (remote desktop) sessions.


import sys
import i3ipc
import shutil
import socket
import tomllib
import subprocess as sp
from pathlib import Path
from getpass import getpass


HOSTNAME = socket.gethostname()
HOME = Path.home()
FREERDP_ARGS = [
    '/clipboard',
]


# Parse command line arguments
try:
    alias = sys.argv[1]
except IndexError:
    print("Provide host alias")
    sys.exit(1)

# Import and set remote host connection attributes
with open(HOME / '.crypt/private_code_vars.toml', 'rb') as f:
    private_code_vars = tomllib.load(f)

match alias:
    case 'a':
        host = "WORK3"
    case 'w':
        host = "WORK4"
    case _:
        print("error: Unknown host alias")
        sys.exit(1)

domain = private_code_vars[host]["domain"]
user = private_code_vars[host]["user"]
try:
    ip = private_code_vars[host]["ip"]
except KeyError:
    ip = ''.join((
        private_code_vars[host]['ip_part1'],
        sys.argv[2],
        private_code_vars[host]["ip_part2"],
    ))

# Determine Sway output (screen) resolution
sway = i3ipc.Connection()
focused_output = next((o for o in sway.get_outputs() if o.focused), None)
if not focused_output:
    raise Exception("Could not determine Sway display resolution")
scale = focused_output.scale
w = focused_output.rect.width * scale
h = focused_output.rect.height * scale
FREERDP_ARGS += [
    '/scale-desktop:' + str(int(scale * 100)),
    # '/scale:180',
    '/w:' + str(int(w - (w * 0.01))),
    '/h:' + str(int(h - (h * 0.1))),
]

# Find and set path to FreeRDP executable
exe = None
for i in (
    'wlfreerdp',
    'sdl3-freerdp3',
):
    exe = shutil.which(i)
    if exe is not None:
        break
if exe is None:
    print("error: No FreeRDP installation detected")
    sys.exit(2)

# Run FreeRDP
cmd = [exe, '/args-from:stdin']
args_str = '\n'.join((
    *FREERDP_ARGS,
    "/d:" + domain,
    "/u:" + user,
    "/v:" + ip,
    "/p:" + getpass(),
))
try:
    sp.run(cmd, text=True, input=args_str)
except KeyboardInterrupt:
    pass

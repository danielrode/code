# List commands by listing all the directories in the PATH variable.


import os
import sys
from pathlib import Path


PATH = os.environ['PATH'].split(':')


def is_exe(path):
    return os.access(path, os.X_OK)


# Parse command line arguments
print_end = '\n'
basename = False
search_term = False

args = iter(sys.argv[1:])
pos_args = []
for a in args:
    if not a.startswith('-'):
        pos_args += [a]
        continue
    match a:
        case '-0' | '--null':
            print_end='\0'
        case '-b' | '--basename':
            basename = True
        case _:
            print("error: Invalid flag", a)
            sys.exit(1)

if len(pos_args) > 0:
    search_term = pos_args[0]

# Print PATH executables
for directory in PATH:
    directory = Path(directory)
    if not directory.exists():
        continue
    for path in directory.iterdir():
        result = path
        if all((
            path.is_file(),
            is_exe(path),
            (not search_term) or (search_term in path.name),
        )):
            if basename:
                result = path.name
            print(result, end=print_end)

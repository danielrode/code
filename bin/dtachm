#!/usr/bin/env python3
# author: daniel rode
# tags: processes, menu
# dependencies:
#   dtach
#   fzf
# created: 12 apr 2025
# updated: 10 jun 2026


# dtach menu. List active dtach sessions in a menu and then connect to the
# selected one.


import os
import re
import sys
import subprocess as sp
from pathlib import Path


DTACH_SOCK_FLAGS = ('-a', '-A', '-c', '-n', '-N', '-p')

PID = os.getpid()


def pgrep(query: str) -> list[list[str]]:
    cmd = ('pgrep', '--list-full', str(query))
    p = sp.run(cmd, text=True, capture_output=True)

    if p.returncode == 0:
        return p.stdout.strip().splitlines()
    elif p.returncode == 1:
        return []
    else:
        raise Exception("pgrep failed: " + str(p))


def get_proc_table():  # Returns iterator
    """Get process table.

    Format and cache a snapshot of information about the current process
    table from the /proc filesystem.
    """

    for p in Path('/proc').iterdir():
        if not p.is_dir():
            continue
        if not p.name.isdigit():
            continue

        status = {
            k.strip(): v.strip()
            for line in Path(p, 'status').read_text().strip().splitlines()
            for k, v in [line.split(':', maxsplit=1)]
        }

        yield {
            'pid': int(p.name),
            'exe': Path(p, 'exe').resolve(),
            'cmd0': Path(p, 'comm').read_text().strip(),
            'cmdline': Path(p, 'cmdline').read_text(),
            'threads': [int(i.name) for i in Path(p, 'task').iterdir()],
            'ppid': int(status['PPid']),
            'state': status['State'].split(' ')[0]
        }


def get_pid_children(pid, ptable):
    return [
        c_pid
        for c_pid in ptable
        if ptable[c_pid]['ppid'] == pid
    ]


def get_dtach_child_cmd(pid, ptable):
    c_pid_list = get_pid_children(pid, ptable)

    assert len(c_pid_list) == 1

    child_pid = c_pid_list[0]
    child_cmd = ptable[child_pid]['cmdline'].replace('\0', ' ')

    return child_cmd


def dtach_is_abandoned(pid, ptable):
    child_pids = get_pid_children(pid, ptable)

    if len(child_pids) > 1:
        return False
    elif len(child_pids) == 0:
        return True
    elif len(child_pids) == 1:
        c_pid = child_pids[0]
    else:
        raise Exception("Negative number of processes? {}".format(child_pids))

    # If dtach only has an inactive shell as a child process, it is abandoned
    if all((
        # Is child process fish shell?
        ptable[c_pid]['exe'].name == 'fish',
        # Is fish childless?
        len(get_pid_children(c_pid, ptable)) == 0,
        # Does fish have any thread workers?
        len(ptable[c_pid]['threads']) == 1,
        # Is fish idle?
        ptable[c_pid]['state'] == 'S',
    )):
        return True
    return False


def count_sock_connnections(sock_path):
    """Return number of active connections the given socket has."""

    cmd = ('lsof', str(sock_path))
    p = sp.run(cmd, text=True, capture_output=True, check=True)

    return len([
        None
        for i in p.stdout.strip().splitlines()
        if re.match(r'.* \(CONNECTED\)$', i)
    ])


# Get current process table
ptable = {
    i['pid']: i
    for i in get_proc_table()
}

# Find active dtach sessions
dtach_socks = dict()
for pid in ptable:
    if ptable[pid]['cmd0'] != 'dtach':
        continue

    flag, sock_path = ptable[pid]['cmdline'].strip('\0').split('\0')[1:3]

    if not Path(sock_path).exists():
        continue

    if dtach_is_abandoned(pid, ptable):
        continue

    if flag not in DTACH_SOCK_FLAGS:
        continue

    dtach_socks[sock_path] = pid

if not dtach_socks:
    sys.exit()

# Display menu of active dtach sessions
cmd = (
    'fzf',
    '--delimiter=\t',
    '--preview=pstree -aps {2}',
    '--preview-window=up,70%',
)
menu = '\n'.join(
    '\t'.join((
        f"[{count_sock_connnections(sock)}]",  # Number of active connections
        str(pid),  # dtach process ID
        sock,  # dtach session socket
        get_dtach_child_cmd(pid, ptable),  # dtach session command
    ))
    for sock, pid in dtach_socks.items()
)
p = sp.run(
    cmd,
    text=True,
    input=menu,
    stdout=sp.PIPE,
)
try:
    sock_path = p.stdout.strip().split('\t')[2]
except IndexError:
    print("No selection made")
    sys.exit()

# Connect to selected dtach session
sp.run(['dtach', '-a', sock_path])



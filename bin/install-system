# author: daniel rode
# created: 12 jan 2026
# updated: 15 may 2026


# Install system files.


import os
import sys
import subprocess as sp
from pathlib import Path


HOME = Path.home()
try:
    CODE_REPO = Path(os.environ['CODE_REPO'])
except KeyError:
    CODE_REPO = HOME / "code"

# 4 = read, 2 = write, 1 = execute
DEFAULT_D_CHMOD = '0755'
DEFAULT_F_CHMOD = '0644'
PERMS = {
    Path('/etc/ssh/sshd_config.d/'):               '0700',
    Path('/etc/ssh/sshd_config.d/99-harden.conf'): '0600',
    Path('/etc/sv/cgroup1000/run'):                '0755',
    Path('/etc/sv/cgroup1000/log/run'):            '0755',
    Path('/usr/local/bin/serve-joplin'):           '0755',
    Path('/usr/local/bin/serve-mumble'):           '0755',
    Path('/usr/local/bin/serve-wishlist'):         '0755',
}


def get_perms(fp):
    try:
        return PERMS[fp]
    except KeyError:
        if fp.is_dir():
            return DEFAULT_D_CHMOD
        return DEFAULT_F_CHMOD


# Verify script is being run as root
if os.geteuid() != 0:
    print("This script must be run as root")
    sys.exit(1)

# Install files
os.chdir(CODE_REPO / 'ins')
for fp in Path('.').rglob('*'):
    dst = Path('/', fp)
    cmd = [
        'install',
        '--verbose',
        '--compare',
        '--backup=existing',
        '--owner=root',
        '--group=root',
        '--mode={}'.format(get_perms(dst)),
    ]
    if fp.is_dir():
        cmd += ['--directory']
    else:
        cmd += [str(fp)]
    cmd += [str(dst)]
    sp.run([*cmd], check=True)

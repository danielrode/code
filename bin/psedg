"""Search and replace stdin using Python regex syntax.
"""


import re
import sys
import signal


# Main
def main():
    # Process command line arguments
    query = sys.argv[1]
    replace = sys.argv[2]

    # Don't make a fus about broken pipes
    signal.signal(signal.SIGPIPE, signal.SIG_DFL)

    # Modify stdin text and print it
    for line in sys.stdin.readlines():
        print(re.sub(query, replace, line), end='')

if __name__ == '__main__':
    main()

#!/usr/bin/env python3
# author: daniel rode
# dependencies: podman, podman-compose, aria2
# created: 07 feb 2026
# updated: 18 may 2026


# Run LLMs (AI chat) locally via llama.cpp.
#
# ssh -tL 5001:localhost:5001 REMOTE_USER@REMOTE_IP sh -c '~/code/bin/lcpp'


import sys
import subprocess as sp
from os import sysconf
from pathlib import Path
from tempfile import TemporaryDirectory

import yaml


HOME = Path.home()
CACHE_DIR = Path(
    HOME,
    ".cache",
    "com.github.danielrode",
    "lcpp",
)
GGUF_MODEL_DIR = CACHE_DIR / "gguf"
MODELS_INI_FP = CACHE_DIR / "models.ini"
RAM_GB = (sysconf('SC_PAGE_SIZE') * sysconf('SC_PHYS_PAGES')) / (1024.**3)

DEFAULT_MODELS = [
    'gemma-3-1b-it-BF16',
    'Falcon3-3B-Instruct-q4_0',
    'Qwen2.5-Coder-3B-Instruct-Q4_0',
]
if RAM_GB > 30:
    DEFAULT_MODELS += [
        'Qwen2.5-7B-Instruct-Q4_0',
        'qwen2.5-coder-7b-instruct-q4_k_m',
        'gemma-4-E4B-it-Q4_0',
    ]
if RAM_GB > 120:
    DEFAULT_MODELS += [
        'Qwen2.5-Coder-14B-Instruct-Q4_0',
        'GLM-4.7-Flash-Q4_0',
        'jan-nano-128k-Q4_1',
    ]
MODEL_LIST = [
    # Useful model lists:
    # - https://huggingface.co/bartowski
    # - https://huggingface.co/unsloth
    # - https://github.com/NVIDIA/RULER
    #
    # Note that the context windows specified are simply the default context
    # window llama.cpp uses for that model, not necessarily the max context
    # window the model supports.
    #
    # 10.7 GB
    'bartowski/gemma-2-9b-it-GGUF:gemma-2-9b-it-Q8_0_L',
    # 8.5 GB | 4k
    'bartowski/Meta-Llama-3.1-8B-Instruct-GGUF:Meta-Llama-3.1-8B-Instruct-Q8_0',
    # 8.5 GB | 4k
    'bartowski/Ministral-8B-Instruct-2410-GGUF:Ministral-8B-Instruct-2410-Q8_0',
    # 4.1 GB | 4k
    'bartowski/Qwen2.5-7B-Instruct-GGUF:Qwen2.5-7B-Instruct-Q4_0',
    # 8.5 GB | 4k
    'bartowski/Qwen2.5-Coder-14B-Instruct-GGUF:Qwen2.5-Coder-14B-Instruct-Q4_0',
    # 16 GB | 4k
    'bartowski/Qwen2.5-Coder-14B-Instruct-GGUF:Qwen2.5-Coder-14B-Instruct-Q8_0',
    # 1.8 GB | 13.5k
    'bartowski/Qwen2.5-Coder-3B-Instruct-GGUF:Qwen2.5-Coder-3B-Instruct-Q4_0',
    # 4.0 GB | 4k
    'Manojb/Qwen3-4B-toolcalling-gguf-codex:Qwen3-4B-Function-Calling-Pro',
    # 2.4 GB
    'Menlo/Jan-nano-128k-gguf:jan-nano-128k-Q4_1',
    # 4.7 GB | 4k
    'Qwen/Qwen2.5-Coder-7B-Instruct-GGUF:qwen2.5-coder-7b-instruct-q4_k_m',
    # 1.9 GB | 4.5k
    'tiiuae/Falcon3-3B-Instruct-GGUF:Falcon3-3B-Instruct-q4_0',
    # 1.8 GB
    'unsloth/gemma-3-1b-it-GGUF:gemma-3-1b-it-BF16',
    # 3.0 GB
    'unsloth/gemma-4-E2B-it-GGUF:gemma-4-E2B-it-Q4_0',
    # 4.8 GB | 4k
    'unsloth/gemma-4-E4B-it-GGUF:gemma-4-E4B-it-Q4_0',
    # 17 GB | 4k
    'unsloth/GLM-4.7-Flash-GGUF:GLM-4.7-Flash-Q4_0',
]
MODEL_MAP = {
    model: repo
    for i in MODEL_LIST
    for repo, model in [i.split(':')]
}

# todo optimize jan settings below
# https://huggingface.co/blog/ggml-org/model-management-in-llamacpp
MODELS_INI = """
[jan-nano-128k-Q4_1]
model = /models/jan-nano-128k-Q4_1.gguf
ctx-size = 131072
flash-attn = true
n-gpu-layers = 16

[Falcon3-3B-Instruct-q4_0]
model = /models/Falcon3-3B-Instruct-q4_0.gguf
ctx-size = 32768
n-gpu-layers = 64

[gemma-4-E4B-it-Q4_0]
model = /models/gemma-4-E4B-it-Q4_0.gguf
ctx-size = 32768
n-gpu-layers = 64
"""

CON_IMG = 'ghcr.io/ggml-org/llama.cpp:server-vulkan'
CON_PORT = 5001
CON_SERVICES = {
    'llamacpp': {
        'image': CON_IMG,
        'devices': [
            '/dev/dri',
        ],
        'volumes': [
            '{}:/etc/lcpp-models.ini:ro,z'.format(MODELS_INI_FP),
            '{}:/models:ro,z'.format(GGUF_MODEL_DIR),
        ],
        'environment': [
            # https://github.com/ggml-org/llama.cpp/blob/master/tools/server/README.md

            'LLAMA_ARG_WEBUI=true',
            'LLAMA_ARG_HOST=0.0.0.0',
            'LLAMA_ARG_PORT={}'.format(CON_PORT),

            # Router mode settings
            'LLAMA_ARG_MODELS_DIR=/models/',
            'LLAMA_ARG_MODELS_PRESET=/etc/lcpp-models.ini',
            'LLAMA_ARG_MODELS_MAX=1',
            # 'LLAMA_ARG_MODELS_MAX=2',
            # 'LLAMA_ARG_MODELS_AUTOLOAD=enabled',
            'LLAMA_ARG_MODELS_AUTOLOAD=disabled',

            # Number of tokens to predict (-1 = inf)
            'LLAMA_ARG_N_PREDICT=-1',

            # Max number of layers to store in VRAM
            'LLAMA_ARG_N_GPU_LAYERS=64',
            # 'LLAMA_ARG_N_GPU_LAYERS=99',
            # 'LLAMA_ARG_N_GPU_LAYERS=auto',
        ],
        'ports': [
            f'127.0.0.1:{CON_PORT}:{CON_PORT}',
        ],
        'restart': 'unless-stopped',
    },
}
CON_COMPOSE = {
    'version': 3.2,
    'services': CON_SERVICES,
}


# Parse command line input
models = [i.removesuffix(".gguf") for i in sys.argv[1:]]
if not models:
    models = DEFAULT_MODELS

for m in models:
    if m not in MODEL_MAP:
        print("error: Model not found:", m)
        sys.exit(1)

# Download model(s), if needed
urls = [
    f'https://huggingface.co/{MODEL_MAP[m]}/resolve/main/{m}.gguf'
    for m in models
    if not Path(GGUF_MODEL_DIR, f"{m}.gguf").exists()
]
if urls:
    GGUF_MODEL_DIR.mkdir(parents=True, exist_ok=True)

    # Aria does not respect name requests for files from Hugging Face last I
    # checked, so this temp dir workaround is needed to ensure model files
    # get proper names
    with TemporaryDirectory(prefix='.tmp_', dir=GGUF_MODEL_DIR) as td:
        td = Path(td)
        for i in range(len(urls)):
            Path(td, str(i)).mkdir()

        aria_input = '\n'.join([
            f"{u}\n\tdir={Path(td, str(i))}"
            for i, u in enumerate(urls)
        ])
        cmd = (
            'aria2c',
            '--force-sequential=true',
            '--input-file=-',
        )
        sp.run(cmd, check=True, text=True, input=aria_input)

        for i, u in enumerate(urls):
            model_fname = u.split('/')[-1]
            model_tmp_fp = next(Path(td, str(i)).glob('*'))
            model_tmp_fp.rename(GGUF_MODEL_DIR / model_fname)

# Write model settings to file
MODELS_INI_FP.write_text(MODELS_INI)

# Update llama.cpp, if needed
cmd = ('podman', 'pull', '--policy=newer', CON_IMG)
sp.run(cmd, check=True)

# Run llama.cpp
cmd = [
    'podman-compose',
    '--file', '-',
]
con_yaml = yaml.dump(CON_COMPOSE)
try:
    p = sp.run([*cmd, 'up'], input=con_yaml, text=True)
    sys.exit(p.returncode)
except KeyboardInterrupt:
    sp.run([*cmd, 'down'], input=con_yaml, text=True)

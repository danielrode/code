# updated: 08 jun 2026


# (Trash)Can. Sends a given set of files to the trash. Accounts for various
# platforms and available tools.


import os
import sys
import time
import shutil
import subprocess as sp
from pathlib import Path


EXE_NAME = Path(__file__).name
HELP_TEXT = f"Usage: {EXE_NAME} PATH..."
HOME = Path.home()

try:
    if os.environ['XDG_DATA_HOME']:
        TRASH_DIR = Path(os.environ['XDG_DATA_HOME'])
    else:
        TRASH_DIR = HOME / ".local/share/Trash"
except KeyError:
    TRASH_DIR = HOME / ".local/share/Trash"


# Functions
def dot_trash(path_list):
    for p in path_list:
        trash_pth = p.parent / ".trash"
        trash_pth.mkdir(exist_ok = True)
        dst_pth = trash_pth / f"{time.time_ns()}_{p.name}"
        if dst_pth.exists():
            print("skipping (dest already exists):", dst_pth)
            continue
        try:
            p.rename(dst_pth)
        except OSError as err:
            print(f"skipping: {p}: {err}")
            continue


def trash_put(path_list):
    sp.run(['trash-put', 'trash', *path_list], check=True)


def gio_trash(path_list):
    sp.run(['gio', 'trash', *path_list], check=True)


def same_filesystem(path_list):
    user_trash_dev_num = os.stat(TRASH_DIR).st_dev
    for p in path_list:
        if os.stat(p).st_dev != user_trash_dev_num:
            return False

    return True


def command_exists(cmd):
    match shutil.which(cmd):
        case None:
            return False
        case _:
            return True


def force_manual_trash_set():
    try:
        if os.environ['DCV_CAN_FORCE_MANUAL_TRASH_YES'] == 'true':
            return True
    except KeyError:
        pass

    return False


# Main
fp_list = []
for fp in sys.argv[1:]:
    fp = Path(fp)

    if not fp.exists():
        print("Skipping (path does not exist):", fp)
        continue

    if fp.is_mount():
        sp.run(['umount', '-v', str(fp)], check=True)

    fp_list += [fp]

if not fp_list:
    print(HELP_TEXT)
    sys.exit(1)
  
if force_manual_trash_set():
    trash_func = dot_trash
elif not same_filesystem(fp_list):
    print("Files not on same filesystem, so moving to .trash/...")
    trash_func = dot_trash
elif command_exists('gio'):
    trash_func = gio_trash
elif command_exists('trash-put'):
    trash_func = trash_put
else:
    trash_func = dot_trash

for fp in fp_list:
    print("Trashing:", fp)
    trash_func([fp])

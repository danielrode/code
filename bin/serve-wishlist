#!/usr/bin/env python3
# author: daniel rode
# dependencies: podman, podman-compose, ~/.nunyuh
# created: 04 may 2026
# updated: 31 may 2026


# Run cmintey's containerized "wishlist" app.


import sys
import tomllib
import subprocess as sp
from pathlib import Path

import yaml


APP_NAME = "cmintey_wishlist"

HOME = Path.home()
DATA_DIR = Path(
    HOME,
    '.local',
    'share',
    'com.github.danielrode',
    'wishlist',
)

NY = tomllib.loads((HOME / '.nunyuh').read_text())['S']['wishlist']

CON_SERVICES = {
    'wishlist': {
        'container_name': 'wishlist',
        'image': 'ghcr.io/cmintey/wishlist:latest',
        'ports': ['127.0.0.1:3000:3000'],
        'volumes': [
            # Where user image uploads get stored
            'uploads:/usr/src/app/uploads',
            # Where the sqlite database gets stored
            'db:/usr/src/app/data',
        ],
        'environment': {
            'ORIGIN': NY['origin'],
            # TOKEN_TIME: 72 # hours until signup and password reset tokens
            # expire
            'TOKEN_TIME': 72,
        },
        'cap_drop': ['ALL'],
        'security_opt': ['no-new-privileges'],
        'read_only': True,
        'tmpfs': ['/tmp:rw,noexec,nosuid,nodev,mode=1700'],
        'restart': 'always',
        'deploy': {'resources': {'limits': {
            'mem_limit': '128m',  # Limit memory usage
            'cpus': 0.5,  # Limit CPU usage to 50% of a single core
        }}},
    },
}
CON_COMPOSE = {
    'services': CON_SERVICES,
    'volumes': {
        'db': {},
        'uploads': {},
    }
}

PODMAN_CMD = (
    'podman-compose',
    '--no-ansi',
    '--podman-pull-args=--pull=missing',
    '--project-name=' + APP_NAME,
    '--file=-',
)


# Main
DATA_DIR.mkdir(exist_ok=True, parents=True, mode=0o700)
try:
    p = sp.run(
        [*PODMAN_CMD, 'up'],
        input=yaml.dump(CON_COMPOSE),
        text=True,
        check=True,
    )
    rc = p.returncode
except KeyboardInterrupt:
    rc = 0

print("Shutting down...")
sp.run(
    [*PODMAN_CMD, 'down'],
    input=yaml.dump(CON_COMPOSE),
    text=True,
)

sys.exit(rc)

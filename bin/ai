#!/usr/bin/env python3
# author: daniel rode
# dependencies: podman, podman-compose, aria2
# created: 28 feb 2026
# updated: 26 apr 2026


# Run llama-swap locally.
#
# ssh -tL 5001:localhost:5001 REMOTE_IP ~/code/bin/ai


import shutil
import socket
import hashlib
import subprocess as sp
from pathlib import Path
from tempfile import TemporaryDirectory

import yaml


HOME = Path.home()
HOSTNAME = socket.gethostname()

MODEL_LIST = [
    # Useful model lists:
    # - https://huggingface.co/bartowski
    # - https://huggingface.co/unsloth
    # 'bartowski/gemma-2-9b-it-GGUF:gemma-2-9b-it-Q8_0_L',  # 10.7 GB
    # 'bartowski/Meta-Llama-3.1-8B-Instruct-GGUF:Meta-Llama-3.1-8B-Instruct-Q8_0',
    # 'bartowski/Ministral-8B-Instruct-2410-GGUF:Ministral-8B-Instruct-2410-Q8_0',  # 8.5 GB
    'bartowski/Qwen2.5-Coder-3B-Instruct-GGUF:Qwen2.5-Coder-3B-Instruct-Q4_0',  # 1.8 GB
    # 'bartowski/Qwen2.5-Coder-14B-Instruct-GGUF:Qwen2.5-Coder-14B-Instruct-Q8_0',  # 16 GB
    # 'Manojb/Qwen3-4B-toolcalling-gguf-codex:Qwen3-4B-Function-Calling-Pro',
    'tiiuae/Falcon3-3B-Instruct-GGUF:Falcon3-3B-Instruct-q4_0',  # 1.9 GB
    'unsloth/gemma-3-1b-it-GGUF:gemma-3-1b-it-BF16',  # 1.8 GB
    # 'unsloth/GLM-4.7-Flash-GGUF:GLM-4.7-Flash-Q4_0',
    'unsloth/gemma-4-E2B-it-GGUF:gemma-4-E2B-it-Q4_0',  # 3.0 GB,

]
match HOSTNAME:
    case 'mesa':
        MODEL_LIST += [
            'bartowski/Qwen2.5-Coder-14B-Instruct-GGUF:Qwen2.5-Coder-14B-Instruct-Q4_0',  # 8.5 GB
            'unsloth/gemma-4-E4B-it-GGUF:gemma-4-E4B-it-Q4_0',  # 4.8
        ]
    case 'bigpan':
        MODEL_LIST += [
            'bartowski/Qwen2.5-7B-Instruct-GGUF:Qwen2.5-7B-Instruct-Q4_0',  # 4.1 GB
            'Qwen/Qwen2.5-Coder-7B-Instruct-GGUF:qwen2.5-coder-7b-instruct-q4_k_m',  # 4.7 GB
            'unsloth/gemma-4-E4B-it-GGUF:gemma-4-E4B-it-Q4_0',  # 4.8
        ]
MODEL_MAP = {
    model: repo
    for i in MODEL_LIST
    for repo, model in [i.split(':')]
}

CON_IMG = 'ghcr.io/mostlygeek/llama-swap:vulkan'
CON_NAME = "llama-swap"
PORT = 5001
# MODEL_CONTEXT = 2**17
MODEL_CONTEXT = 0

GGUF_MODEL_DIR = HOME / ".cache/com.github.danielrode/lcpp/gguf"


def sha1(text: str) -> str:
    """Return SHA1 hash of string."""

    return hashlib.sha1(bytes(text, 'utf8')).hexdigest()


def get_llama_swap_conf_yaml():
    # https://github.com/mostlygeek/llama-swap/blob/main/docs/configuration.md
    return yaml.dump({'models': {
        model: {
            'cmd': ' '.join((
                'llama-server',
                '--no-webui',
                '--port', '${PORT}',
                '--model', '/models/' + model + '.gguf',
                # Size of the prompt context (0 = loaded from model)
                '--ctx-size', str(MODEL_CONTEXT),
                '--jinja',
            )),
        }
        for model in MODEL_MAP
    }})


def get_compose_yaml(llama_swap_yaml_path, port=PORT):
    return yaml.dump({
        'version': 3.2,
        'services': {
            'llama-swap': {
                'container_name': CON_NAME,
                'image': CON_IMG,
                'networks': ['ai'],
                'devices': ['/dev/dri'],
                'volumes': [
                    str(GGUF_MODEL_DIR) + ':/models:ro,z',
                    str(llama_swap_yaml_path) + ':/app/config.yaml:ro,z',
                ],
                'ports': [f'127.0.0.1:{port}:{port}'],
                'restart': 'unless-stopped',
                'entrypoint': [
                    "/app/llama-swap",
                    '-config', '/app/config.yaml',
                    '-listen', f'0.0.0.0:{port}',
                ],
            },
        },
        'networks': {
            'ai': {
                'name': 'ai',
                'internal': True,  # Disable internet access
            },
        },
    })


# Main

# Download models
GGUF_MODEL_DIR.mkdir(exist_ok=True, parents=True)

urls = []
for model in MODEL_MAP:
    repo = MODEL_MAP[model]
    fname = model + ".gguf"
    if not (GGUF_MODEL_DIR / fname).exists():
        u = f'https://huggingface.co/{repo}/resolve/main/{fname}'
        hash = sha1(u)
        dst = Path(GGUF_MODEL_DIR, '.tmp_aria', hash)
        dst.mkdir(parents=True, exist_ok=True)
        urls += [{
            'repo': repo,
            'fname': fname,
            'url': u,
            'hash': hash,
            'tmp_dst_dir': dst,
        }]

if urls:
    aria_input = '\n'.join([
        f"{i['url']}\n\tdir={i['tmp_dst_dir']}"
        for i in urls
    ])
    cmd = (
        'aria2c',
        '--force-sequential=true',
        '--input-file=-',
    )
    sp.run(cmd, check=True, text=True, input=aria_input)

    for i in urls:
        next(i['tmp_dst_dir'].glob('*')).rename(GGUF_MODEL_DIR / i['fname'])

    shutil.rmtree(GGUF_MODEL_DIR / '.tmp_aria')

# Fetch latest container image, if needed
cmd = ('podman', 'pull', '--policy=newer', CON_IMG)
sp.run(cmd, check=True)

# Run llama.cpp
sp.run(['podman', 'rm', '--force', CON_NAME], check=True)
cmd = (
    'podman-compose',
    '--file', '-',
    'up',
)
with TemporaryDirectory() as tmpdir:
    llama_swap_conf_yaml = Path(tmpdir, "conf.yaml")
    llama_swap_conf_yaml.write_text(get_llama_swap_conf_yaml())

    con_yaml = get_compose_yaml(llama_swap_conf_yaml)
    try:
        sp.run(cmd, input=con_yaml, text=True)
    except KeyboardInterrupt:
        pass

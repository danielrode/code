#!/usr/bin/env python3
# author: daniel rode
# dependencies: podman, podman-compose, aria2
# created: 28 feb 2026
# updated: 02 mar 2026


# Run llama-swap locally.
#
# ssh -tL 5001:localhost:5001 REMOTE_IP /home/daniel/code/bin/ai Qwen2.5-7B-Instruct-Q4_0.gguf


import sys
import subprocess as sp
from pathlib import Path
from tempfile import TemporaryDirectory

import yaml


DEFAULT_MODEL = 'gemma-3-1b-it-BF16.gguf'
MODEL_URL_MAP = {i.split('/')[-1]: i for i in (
    # Useful model lists:
    # - https://huggingface.co/bartowski
    # - https://huggingface.co/unsloth
    'https://huggingface.co/bartowski/gemma-2-9b-it-GGUF/resolve/main/gemma-2-9b-it-Q8_0_L.gguf',
    'https://huggingface.co/bartowski/Meta-Llama-3.1-8B-Instruct-GGUF/resolve/main/Meta-Llama-3.1-8B-Instruct-Q8_0.gguf',
    'https://huggingface.co/bartowski/Ministral-8B-Instruct-2410-GGUF/resolve/main/Ministral-8B-Instruct-2410-Q8_0.gguf',
    'https://huggingface.co/bartowski/Qwen2.5-7B-Instruct-GGUF/resolve/main/Qwen2.5-7B-Instruct-Q4_0.gguf',
    'https://huggingface.co/bartowski/Qwen2.5-Coder-14B-Instruct-GGUF/resolve/main/Qwen2.5-Coder-14B-Instruct-Q8_0.gguf',
    'https://huggingface.co/Manojb/Qwen3-4B-toolcalling-gguf-codex/resolve/main/Qwen3-4B-Function-Calling-Pro.gguf',
    'https://huggingface.co/tiiuae/Falcon3-3B-Instruct-GGUF/resolve/main/Falcon3-3B-Instruct-q4_0.gguf',
    'https://huggingface.co/unsloth/gemma-3-1b-it-GGUF/resolve/main/gemma-3-1b-it-BF16.gguf',
    'https://huggingface.co/unsloth/GLM-4.7-Flash-GGUF/resolve/main/GLM-4.7-Flash-Q4_0.gguf',
)}

PORT = 5001
# MODEL_CONTEXT = 2**17
MODEL_CONTEXT = 0

HOME = Path.home()
DATA_DIR = HOME / ".local/share/com.github.danielrode/ai"
GGUF_MODEL_DIR = HOME / ".cache/com.github.danielrode/lcpp/gguf"


def get_llama_swap_conf_yaml():
    return yaml.dump({'models': {
        k.removesuffix(".gguf"): {
            'cmd': ' '.join((
                'llama-server',
                '--port=${PORT}',
                '--model=/models/' + k,
                # Size of the prompt context (0 = loaded from model)
                '--ctx-size=' + str(MODEL_CONTEXT),
            ))
        }
        for k in MODEL_URL_MAP
        if (GGUF_MODEL_DIR / k).exists()
    }})


def get_con_yaml(model_filename, llama_swap_yaml_path, port=PORT):
    return yaml.dump({
        'version': 3.2,
        'services': {
            'llama-server': {
                'image': 'ghcr.io/mostlygeek/llama-swap:vulkan',
                'devices': [
                    '/dev/dri',
                ],
                'volumes': [
                    str(GGUF_MODEL_DIR) + ':/models:ro,z',
                    str(llama_swap_yaml_path) + ':/app/config.yaml:ro,z',
                ],
                'ports': [
                    # f'127.0.0.1:{port}:{8080}',
                    f'{port}:{8080}',
                ],
                'restart': 'unless-stopped',
            },
        },
    })


# Main

# Parse command line input
try:
    model_filename = sys.argv[1]
except IndexError:
    model_filename = DEFAULT_MODEL

if model_filename not in MODEL_URL_MAP:
    print("error: Model not found:", model_filename)
    sys.exit(1)

# Download model, if needed
if not (GGUF_MODEL_DIR / model_filename).exists():
    print("Model file not found; downloading...")
    GGUF_MODEL_DIR.mkdir(exist_ok=True, parents=True)
    cmd = (
        'aria2c',
        '--dir', str(GGUF_MODEL_DIR),
        '--out', str(model_filename),
        MODEL_URL_MAP[model_filename],
    )
    sp.run(cmd, check=True)

# Run llama.cpp
cmd = (
    'podman-compose',
    '--file', '-',
    'up',
)
with TemporaryDirectory() as tmpdir:
    llama_swap_conf_yaml = Path(tmpdir, "conf.yaml")
    llama_swap_conf_yaml.write_text(get_llama_swap_conf_yaml())

    con_yaml = get_con_yaml(model_filename, llama_swap_conf_yaml)
    sp.run(cmd, input=con_yaml, text=True)

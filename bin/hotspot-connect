"""Connect to mobile hotspot.
"""


import tomllib
import subprocess as sp
from pathlib import Path


HOME = Path.home()
VARS_PATH = Path(HOME, '.crypt', 'private_code_vars.toml')
VARS = tomllib.loads(VARS_PATH.read_text())


cmd = (
    str(HOME / 'code/bin/wconnect'),
    'w', VARS['PHONE']['hotspot_name']
)
sp.run(cmd, check=True)

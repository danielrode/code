pomodoro  # Eye Timer
~/code/bin/redx  # Overlay Red Crosshair
wl-copy 'https://www.amazon.com/dp/'`wl-paste | sed 's,.*/dp/,,' | sed 's,[/\?].*,,'`  # Shorten Amazon clipboard link
nm-connection-editor  # Network Manager (wifi, eth)
wlsunset -s 00:00 -t 5000 -g 1.5  # Nice screen (gentle contrast and temp)
~/code/bin/dim  # Dim screen (reduce brightness)
sudo vsv up waydroid-container && waydroid app launch eu.faircode.email  # FairEmail (Android app)
wl-paste | nl -w 1 -s ' ' | wl-copy  # Enumerate/count/number clipboard lines
swaymsg input type:touchpad dwt disable  # Allow touchpad while keyboarding/typing



#!/usr/bin/env python3
# author: daniel rode
# created: 12 jan 2026
# updated: 01 apr 2026


# Install system files.


import os
import sys
import subprocess as sp
from pathlib import Path


HOME = Path.home()
DRYRUN = False
try:
    CODE_REPO = Path(os.environ['CODE_REPO'])
except KeyError:
    CODE_REPO = HOME / "code"


# Verify script is being run as root
if os.geteuid() != 0:
    print("This script must be run via `sudo -E`")
    sys.exit(1)

# Determine whether to make actual changes, or just simulate them
try:
    if os.environ['dryrun'] == "true":
        DRYRUN = True
except KeyError:
    pass

# Install config files
args = [
    'rsync',

    # Configure rsync information verbosity and format
    '--verbose',
    '--human-readable',
    '--itemize-changes',

    # Configure rsync data transfer method
    '--fsync',
    '--recursive',  # Copy source recursively

    # Set permissions
    # "...to give destination files (both old and new) the source
    # permissions, use --perms.  To give new files the destination-default
    # permissions (while leaving existing files unchanged), make sure that
    # the --perms option is off and use --chmod..."
    # '--perms', '--chmod=D755,F644',
    '--chmod=D755,F644',
    '--chown=root:root',

    '--links',  # Copy symlinks as symlinks
    '--backup-dir=/etc/.trash',  # Keep backup of existing dest file
    '--mkpath',  # Create destination if it does not exist
    '--checksum',  # Copy file again even if size and times match dest
    '--omit-dir-times',
    '--omit-link-times',
]
if DRYRUN:
    args += ['--dry-run']
args += [
    str(CODE_REPO / 'ins/system') + '/',  # Source
    '/',  # Destination
]
sp.run(args, check=True)

# Fix permissions
if DRYRUN:
    sys.exit(0)
for perms in (
    ['0700', '/etc/ssh/sshd_config.d/'],
    ['0600', '/etc/ssh/sshd_config.d/99-harden.conf'],
    ['0755', '/etc/sv/cgroup1000/run'],
    ['0755', '/etc/sv/cgroup1000/log/run'],
):
    sp.run(['chmod', '--changes', *perms], check=True)

#!/usr/bin/env python3
# author: daniel rode
# created: 10 oct 2025
# updated: 27 may 2026


# Create BTRFS snapshots.

# NOTE: On many distros, /home is a BTRFS subvolume by default, but not the
# user's home directory. You can not take a direct snapshot of a directory
# unless it is a subvolume. Run `sudo btrfs subvolume show ~`, and if it
# says "Not a Btrfs subvolume: Invalid argument", then your home directory
# is not a subvolume. You can migrate it to a subvolume using the following
# command sequence:
#   sudo home="$HOME" su
#   set -e
#   lsof | grep '[0-9][uw]' | grep "$home"  # List user files open for write
#   # Terminate listed processes
#   mv "$home" "$home".old
#   btrfs subvolume create "$home"
#   chmod --reference="$home".old "$home"
#   chown --reference="$home".old "$home"
#   chcon --reference="$home".old "$home"
#   getfacl "$home".old | setfacl --set-file=- "$home"
#   cp -axv --reflink=always "$home".old/. "$home"
#   reboot
#   # After reboot finishes, open up unprivledged shell as your regular user
#   # and create a subvolume for your home dir snapshots:
#   btrfs subvolume create ~/.snapshots
#
# NOTE: You can exclude ~/downloads and ~/.cache from ~/ snapshots by
# making them their own subvolumes (BTRFS snapshots do not recurse into
# subvolumes).


import os
import json
import subprocess as sp
from pathlib import Path
from datetime import datetime


INCLUDE_DIRS = [
    Path.home(),
    Path('/home/'),
]

BTRFS_RO_ERR = 'ERROR: Could not create subvolume: Read-only file system'


def timestamp() -> str:
    return datetime.now().strftime('%Y-%m-%d-%H%M%S')


def ls_btrfs(exclusions=['/', '/home']) -> list[Path]:
    cmd = (
        'findmnt',
        '--list',
        '--noheadings',
        '--types', 'btrfs',
        '--output', 'TARGET',
        '--json',
    )
    p = sp.run(cmd, check=True, text=True, capture_output=True)

    return [
        Path(i['target'])
        for i in json.loads(p.stdout)['filesystems']
        if i['target'] not in exclusions
    ]


# Create read-only BTRFS snapshots
for btrfs_subvol in (INCLUDE_DIRS + ls_btrfs()):
    if not btrfs_subvol.exists():
        continue

    snapshot_dir = btrfs_subvol / '.snapshots'
    if not snapshot_dir.exists():
        print("No snapshot directory found (skipping):", btrfs_subvol)
        continue

    cmd = []
    if not os.access(btrfs_subvol, os.W_OK | os.X_OK):
        cmd += ['sudo']

    cmd += [
        'btrfs',
        'subvolume',
        'snapshot',
        '-r',  # Make snapshot read-only
        str(btrfs_subvol),
        str(Path(btrfs_subvol, '.snapshots', f"@snapshot-{timestamp()}")),
    ]
    p = sp.run(cmd, text=True, stdout=sp.PIPE, stderr=sp.STDOUT)

    if p.stdout.strip() == BTRFS_RO_ERR:
        print("Read-only filesystem (skipping):", btrfs_subvol)
    else:
        print(p.stdout, end='')
